{% extends "partials/new_layout.twig" %}

{% block content %}
<div class="sz-dashboard">

    <div class="sz-dash-header">
        <div>
            <h1 class="sz-dash-title">{{ title }}</h1>
            <p class="sz-dash-sub">
                <a href="{{ 'proveedores'|url }}" class="sz-back-link">
                    <i class="fas fa-arrow-left mr-1"></i> Volver a proveedores
                </a>
            </p>
        </div>
    </div>

    <form id="formProveedor">
        <input type="hidden" name="id" value="{{ model.id }}">

        <div class="row">
            <div class="col-lg-8">
                <div class="sz-dash-card animate-in mb-3" style="--delay:.05s">
                    <div class="sz-card-header">
                        <span class="sz-card-title"><i class="fas fa-building"></i> Datos del proveedor</span>
                    </div>
                    <div class="p-4">

                        <div class="form-group">
                            <label for="nombre">Nombre del proveedor *</label>
                            <input type="text" class="form-control" id="nombre" name="nombre"
                                   value="{{ model.nombre }}" placeholder="Razón social o nombre comercial" required>
                            <span class="form-validation-failed" id="err-nombre"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="contacto">Nombre del contacto</label>
                                    <input type="text" class="form-control" id="contacto" name="contacto"
                                           value="{{ model.contacto }}" placeholder="Persona de contacto">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="rfc">RFC</label>
                                    <input type="text" class="form-control" id="rfc" name="rfc"
                                           value="{{ model.rfc }}" placeholder="RFC del proveedor"
                                           maxlength="13" style="text-transform:uppercase">
                                    <span class="form-validation-failed" id="err-rfc"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="telefono">Teléfono</label>
                                    <input type="text" class="form-control" id="telefono" name="telefono"
                                           value="{{ model.telefono }}" placeholder="000-000-0000">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="email">Correo electrónico</label>
                                    <input type="email" class="form-control" id="email" name="email"
                                           value="{{ model.email }}" placeholder="correo@proveedor.com">
                                    <span class="form-validation-failed" id="err-email"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="direccion">Dirección</label>
                            <textarea class="form-control" id="direccion" name="direccion"
                                      rows="2" placeholder="Dirección completa del proveedor">{{ model.direccion }}</textarea>
                        </div>

                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="sz-dash-card animate-in" style="--delay:.1s">
                    <div class="sz-card-header">
                        <span class="sz-card-title"><i class="fas fa-id-card"></i> Resumen</span>
                    </div>
                    <div class="p-4 text-center">
                        <div class="sz-prov-avatar-lg mx-auto mb-3" id="avatarPreview">
                            {{ model.nombre ? model.nombre|slice(0,2)|upper : '??' }}
                        </div>
                        <p class="sz-prod-nombre" id="nombrePreview">{{ model.nombre ?? 'Nombre del proveedor' }}</p>
                        <p class="sz-prod-desc" id="rfcPreview">{{ model.rfc ?? 'RFC' }}</p>
                    </div>
                </div>

                <div class="sz-dash-card animate-in mt-3" style="--delay:.15s">
                    <div class="p-3">
                        <button type="submit" class="btn btn-sz btn-block" id="btnGuardar">
                            <i class="fas fa-save mr-2"></i> Guardar proveedor
                        </button>
                        <a href="{{ 'proveedores'|url }}" class="btn btn-outline-secondary btn-block mt-2">
                            Cancelar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
<script>
$(document).ready(function () {

    // RFC a mayúsculas automático
    $('#rfc').on('input', function () {
        $(this).val($(this).val().toUpperCase());
        $('#rfcPreview').text($(this).val() || 'RFC');
    });

    $('#nombre').on('input', function () {
        const val = $(this).val();
        $('#nombrePreview').text(val || 'Nombre del proveedor');
        $('#avatarPreview').text(val ? val.substring(0, 2).toUpperCase() : '??');
    });

    $('#formProveedor').on('submit', function (e) {
        e.preventDefault();
        $('.form-validation-failed').text('');

        $('#btnGuardar').prop('disabled', true)
            .html('<i class="fas fa-spinner fa-spin mr-2"></i> Guardando...');

        $.ajax({
            url: base_url('proveedores/guardar'), method: 'POST',
            data: $(this).serialize(), dataType: 'json',
            success: function (res) {
                if (res.response) {
                    redirect(res.href || 'proveedores');
                } else if (res.validations) {
                    $.each(res.validations, function (campo, msg) {
                        if (msg) $('#err-' + campo).text(msg);
                    });
                    $('#btnGuardar').prop('disabled', false)
                        .html('<i class="fas fa-save mr-2"></i> Guardar proveedor');
                } else {
                    alert(res.message || 'Error al guardar');
                    $('#btnGuardar').prop('disabled', false)
                        .html('<i class="fas fa-save mr-2"></i> Guardar proveedor');
                }
            },
            error: function () {
                alert('Error de conexión');
                $('#btnGuardar').prop('disabled', false)
                    .html('<i class="fas fa-save mr-2"></i> Guardar proveedor');
            }
        });
    });
});
</script>
{% endblock %}
