{% extends "partials/new_layout.twig" %}

{% block content %}
<div class="sz-dashboard">

    <div class="sz-dash-header">
        <div>
            <h1 class="sz-dash-title">Órdenes de compra</h1>
            <p class="sz-dash-sub">
                <a href="{{ 'proveedores'|url }}" class="sz-back-link">
                    <i class="fas fa-arrow-left mr-1"></i> Volver
                </a>
            </p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <div class="sz-prov-info">
                <div class="sz-prov-avatar">{{ proveedor.nombre|slice(0,2)|upper }}</div>
                <div>
                    <span class="sz-prod-nombre">{{ proveedor.nombre }}</span>
                    <small class="sz-prod-desc">{{ proveedor.contacto ?? '' }}</small>
                </div>
            </div>
            <a href="{{ ('proveedores/nuevaOrden/' ~ proveedor.id)|url }}" class="btn btn-sz ml-3">
                <i class="fas fa-plus mr-2"></i> Nueva orden
            </a>
        </div>
    </div>

    <div class="sz-dash-card animate-in" style="--delay:.05s">
        <div class="sz-card-header">
            <span class="sz-card-title"><i class="fas fa-file-invoice"></i> Historial de órdenes</span>
        </div>

        {% if ordenes|length > 0 %}
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Folio</th>
                        <th>Fecha</th>
                        <th>Creada por</th>
                        <th>Entrega est.</th>
                        <th class="text-center">Estado</th>
                        <th class="text-right">Total</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {% for orden in ordenes %}
                    <tr>
                        <td><code class="sz-codigo">#{{ orden.id|padLeft(5) }}</code></td>
                        <td><small class="text-muted">{{ orden.created_at|date('d/m/Y H:i') }}</small></td>
                        <td>{{ orden.usuario.nombre ?? '—' }}</td>
                        <td>
                            {% if orden.fecha_entrega %}
                                <small>{{ orden.fecha_entrega|date('d/m/Y') }}</small>
                            {% else %}
                                <small class="text-muted">—</small>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            <span class="sz-pedido-estado sz-estado-orden--{{ orden.estado }}">
                                {{ orden.estado|capitalize }}
                            </span>
                        </td>
                        <td class="text-right sz-venta-monto">${{ orden.total|number_format(2, '.', ',') }}</td>
                        <td class="text-center">
                            <a href="{{ ('proveedores/detalleOrden/' ~ orden.id)|url }}"
                               class="btn btn-sm btn-outline-secondary mr-1" title="Ver detalle">
                                <i class="fas fa-eye"></i>
                            </a>
                            {% if orden.estado == 'pendiente' %}
                            <button class="btn btn-sm btn-sz btn-recibir"
                                    data-id="{{ orden.id }}" title="Marcar como recibida">
                                <i class="fas fa-check"></i>
                            </button>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div class="sz-empty" style="padding:3rem">
            <i class="fas fa-file-invoice fa-2x mb-3 d-block" style="color:var(--sz-border)"></i>
            Sin órdenes de compra para este proveedor
        </div>
        {% endif %}
    </div>
</div>

{# Modal confirmar recepción #}
<div class="modal fade" id="modalRecibir" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content sz-modal">
            <div class="modal-header">
                <h5 class="modal-title">Confirmar recepción</h5>
                <button type="button" class="close" data-dismiss="modal"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                ¿Confirmas la recepción de la orden <strong id="folioOrden"></strong>?
                El stock de los productos se actualizará automáticamente.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-sz" id="btnConfirmarRecibir">
                    <i class="fas fa-check mr-1"></i> Confirmar recepción
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
$(document).ready(function () {
    let idOrden = null;

    $(document).on('click', '.btn-recibir', function () {
        idOrden = $(this).data('id');
        $('#folioOrden').text('#' + String(idOrden).padStart(5, '0'));
        $('#modalRecibir').modal('show');
    });

    $('#btnConfirmarRecibir').on('click', function () {
        if (!idOrden) return;
        $(this).prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Procesando...');

        $.ajax({
            url: base_url('proveedores/estadoOrden'), method: 'POST',
            data: { id: idOrden, estado: 'recibida' }, dataType: 'json',
            success: function (res) {
                if (res.response) { $('#modalRecibir').modal('hide'); location.reload(); }
                else alert(res.message);
            },
            complete: function () {
                $('#btnConfirmarRecibir').prop('disabled', false)
                    .html('<i class="fas fa-check mr-1"></i> Confirmar recepción');
            }
        });
    });
});
</script>
{% endblock %}
