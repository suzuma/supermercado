{% extends 'partials/tienda_layout.twig' %}

{% block content %}
<div class="container py-4">
    <h2 class="sz-section-title">Mis pedidos</h2>
    <p class="text-muted">Hola, <strong>{{ cliente.nombre }}</strong> — aquí puedes ver el estado de tus pedidos.</p>

    {% if pedidos|length > 0 %}
    <div class="row">
        {% for pedido in pedidos %}
        <div class="col-12 mb-3">
            <div class="sz-tienda-card">
                <div class="sz-tienda-card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Pedido <code class="sz-codigo">#{{ pedido.id|padLeft(5) }}</code></h6>
                    <div class="d-flex align-items-center gap-2">
                        <small class="text-muted">{{ pedido.created_at|date('d/m/Y H:i') }}</small>
                        <span class="sz-pedido-estado sz-estado--{{ pedido.estado }}">{{ pedido.estado|capitalize }}</span>
                        {% if pedido.estado == 'pendiente' %}
                        <button class="btn btn-sm btn-outline-danger btn-cancelar-pedido"
                                data-id="{{ pedido.id }}"
                                title="Cancelar pedido">
                            <i class="fas fa-times"></i> Cancelar
                        </button>
                        {% endif %}
                    </div>
                </div>
                <div class="p-3">
                    {# Timeline #}
                    <div class="sz-timeline mb-3">
                        {% set estados = ['pendiente', 'confirmado', 'enviado', 'entregado'] %}
                        {% for est in estados %}
                        {% set activo = (
                            est == 'pendiente' or
                            (est == 'confirmado' and pedido.estado in ['confirmado','enviado','entregado']) or
                            (est == 'enviado'    and pedido.estado in ['enviado','entregado']) or
                            (est == 'entregado'  and pedido.estado == 'entregado')
                        ) %}
                        <div class="sz-timeline-item {% if activo %}sz-timeline-item--done{% endif %} {% if est == pedido.estado %}sz-timeline-item--current{% endif %}">
                            <div class="sz-timeline-dot">{% if activo %}<i class="fas fa-check"></i>{% endif %}</div>
                            <div class="sz-timeline-label">{{ est|capitalize }}</div>
                        </div>
                        {% if not loop.last %}
                        <div class="sz-timeline-line {% if activo %}sz-timeline-line--done{% endif %}"></div>
                        {% endif %}
                        {% endfor %}
                    </div>

                    {# Productos #}
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <tbody>
                                {% for det in pedido.detalles %}
                                <tr>
                                    <td>{{ det.producto.nombre }}</td>
                                    <td class="text-center">x{{ det.cantidad }}</td>
                                    <td class="text-right">{{ _cfg.simbolo }}{{ det.subtotal|number_format(2, '.', ',') }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="2" class="text-right font-weight-bold">Total</td>
                                    <td class="text-right font-weight-bold">{{ _cfg.simbolo }}{{ pedido.total|number_format(2, '.', ',') }}</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <div class="text-center py-5">
        <i class="fas fa-box-open fa-3x mb-3" style="color:var(--sz-border)"></i>
        <p class="text-muted">Aún no tienes pedidos</p>
        <a href="{{ 'tienda/catalogo'|url }}" class="btn btn-sz mt-2">
            <i class="fas fa-store mr-2"></i> Ir al catálogo
        </a>
    </div>
    {% endif %}
</div>

<div class="modal fade" id="modalCancelar" tabindex="-1" role="dialog" aria-labelledby="modalCancelarLabel" aria-modal="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalCancelarLabel">
                    <i class="fas fa-exclamation-triangle text-warning mr-2"></i> Cancelar pedido
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>¿Estás seguro de que deseas cancelar el pedido <strong id="folioModal"></strong>?</p>
                <p class="text-muted mb-0" style="font-size:.875rem;">
                    Esta acción no se puede deshacer. El stock de los productos será restaurado.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">No, mantener pedido</button>
                <button type="button" class="btn btn-danger" id="btnConfirmarCancelar">
                    <i class="fas fa-times mr-1"></i> Sí, cancelar
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
var pedidoCancelarId = null;

$(document).on('click', '.btn-cancelar-pedido', function () {
    pedidoCancelarId = $(this).data('id');
    $('#folioModal').text('#' + String(pedidoCancelarId).padStart(5, '0'));
    $('#modalCancelar').modal('show');
});

$('#btnConfirmarCancelar').on('click', function () {
    if (!pedidoCancelarId) return;

    var $btn = $(this);
    $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Cancelando...');

    $.ajax({
        url: base_url('tienda/cancelar-pedido'), method: 'POST',
        data: { pedido_id: pedidoCancelarId },
        dataType: 'json',
        success: function (res) {
            $('#modalCancelar').modal('hide');
            if (res.response) {
                window.location.reload();
            } else {
                alert(res.message);
                $btn.prop('disabled', false).html('<i class="fas fa-times mr-1"></i> Sí, cancelar');
            }
        },
        error: function () {
            $('#modalCancelar').modal('hide');
            alert('Error de conexión. Intenta de nuevo.');
            $btn.prop('disabled', false).html('<i class="fas fa-times mr-1"></i> Sí, cancelar');
        }
    });
});
</script>
{% endblock %}
