{% extends 'partials/tienda_layout.twig' %}
{% block content %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="sz-tienda-card">
                <div class="sz-tienda-card-header text-center">
                    <h5 class="mb-0"><i class="fas fa-lock mr-2"></i> Nueva contraseña</h5>
                </div>
                <div class="p-4">
                    <p class="text-muted mb-4">Elige una nueva contraseña para tu cuenta.</p>
                    <form id="formNuevaPassword">
                        <input type="hidden" name="token" value="{{ token }}">
                        <div class="form-group">
                            <label for="inputPassword">Nueva contraseña</label>
                            <input type="password" id="inputPassword" class="form-control"
                                   name="password" required placeholder="Mínimo 6 caracteres"
                                   autocomplete="new-password">
                        </div>
                        <div class="form-group">
                            <label for="inputConfirm">Confirmar contraseña</label>
                            <input type="password" id="inputConfirm" class="form-control"
                                   name="password_confirm" required placeholder="Repite la contraseña"
                                   autocomplete="new-password">
                        </div>
                        <div id="nuevaPasswordMsg" class="alert d-none"></div>
                        <button type="submit" class="btn btn-sz btn-block" id="btnGuardar">
                            <i class="fas fa-save mr-2"></i> Guardar contraseña
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
$('#formNuevaPassword').on('submit', function (e) {
    e.preventDefault();
    const $msg = $('#nuevaPasswordMsg');
    const $btn = $('#btnGuardar');

    $msg.addClass('d-none').removeClass('alert-success alert-danger');
    $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-2"></i> Guardando...');

    $.ajax({
        url: base_url('tienda/nueva-password'), method: 'POST',
        data: $(this).serialize(), dataType: 'json',
        success: function (res) {
            if (res.response) {
                $msg.addClass('alert-success').text(res.message).removeClass('d-none');
                $('#formNuevaPassword input:not([name="token"])').prop('disabled', true);
                $btn.prop('disabled', true).html('<i class="fas fa-check mr-2"></i> Guardado');
                setTimeout(function () {
                    window.location.href = base_url(res.href);
                }, 2000);
            } else {
                $msg.addClass('alert-danger').text(res.message).removeClass('d-none');
                $btn.prop('disabled', false).html('<i class="fas fa-save mr-2"></i> Guardar contraseña');
            }
        },
        error: function () {
            $msg.addClass('alert-danger').text('Error de conexión').removeClass('d-none');
            $btn.prop('disabled', false).html('<i class="fas fa-save mr-2"></i> Guardar contraseña');
        }
    });
});
</script>
{% endblock %}
