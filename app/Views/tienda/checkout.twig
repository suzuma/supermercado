{% extends 'partials/tienda_layout.twig' %}


{% block content %}
<div class="container py-4">
    <h2 class="sz-section-title">Finalizar compra</h2>

    <div class="row">
        <div class="col-lg-7 mb-4">
            <div class="sz-tienda-card">
                <div class="sz-tienda-card-header">
                    <h6 class="mb-0"><i class="fas fa-map-marker-alt mr-2"></i> Dirección de entrega</h6>
                </div>
                <div class="p-4">
                    <div class="form-group">
                        <label>Calle y número *</label>
                        <input type="text" class="form-control" id="checkoutCalle"
                               placeholder="Ej. Av. Reforma 123" autocomplete="street-address">
                    </div>
                    <div class="form-row">
                        <div class="form-group col-md-4">
                            <label>Código postal *</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="checkoutCP"
                                       placeholder="00000" maxlength="5" inputmode="numeric" autocomplete="postal-code">
                                <div class="input-group-append" id="cpSpinner" style="display:none">
                                    <span class="input-group-text"><i class="fas fa-spinner fa-spin"></i></span>
                                </div>
                            </div>
                        </div>
                        <div class="form-group col-md-8">
                            <label>Colonia *</label>
                            <select class="form-control" id="checkoutColonia" disabled>
                                <option value="">— Ingresa tu CP primero —</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-row" id="rowCiudad" style="display:none;">
                        <div class="form-group col-md-6">
                            <label>Ciudad</label>
                            <input type="text" class="form-control" id="checkoutCiudad" readonly>
                        </div>
                        <div class="form-group col-md-6">
                            <label>Estado</label>
                            <input type="text" class="form-control" id="checkoutEstado" readonly>
                        </div>
                    </div>
                    <div class="form-group mb-0">
                        <label>Teléfono de contacto</label>
                        <input type="text" class="form-control" id="checkoutTelefono"
                               value="{{ cliente.telefono ?? '' }}" placeholder="000-000-0000" inputmode="tel">
                    </div>
                </div>
            </div>

            {# Puntos de lealtad #}
            {% if saldo_puntos >= cfg_puntos.minimo_puntos_canje %}
            <div class="sz-tienda-card mt-3">
                <div class="sz-tienda-card-header">
                    <h6 class="mb-0"><i class="fas fa-star mr-2 text-warning"></i> Puntos de lealtad</h6>
                </div>
                <div class="p-4">
                    <p class="mb-2">
                        Tienes <strong class="text-warning">{{ saldo_puntos }} puntos</strong>
                        (equivalen a <strong>${{ (saldo_puntos * cfg_puntos.valor_punto)|number_format(2, '.', ',') }}</strong>).
                    </p>
                    <div class="form-group mb-2">
                        <label for="inputPuntos">¿Cuántos puntos quieres canjear?</label>
                        <div class="input-group">
                            <input type="number" id="inputPuntos" class="form-control"
                                   min="{{ cfg_puntos.minimo_puntos_canje }}"
                                   max="{{ saldo_puntos }}" step="1"
                                   placeholder="Mín. {{ cfg_puntos.minimo_puntos_canje }}">
                            <div class="input-group-append">
                                <button class="btn btn-outline-warning" id="btnAplicarPuntos" type="button">
                                    Canjear
                                </button>
                            </div>
                        </div>
                    </div>
                    <div id="puntosMsg" class="d-none" style="font-size:.85rem;"></div>
                </div>
            </div>
            {% elseif saldo_puntos > 0 %}
            <div class="sz-tienda-card mt-3">
                <div class="p-3 text-muted small">
                    <i class="fas fa-star mr-1 text-warning"></i>
                    Tienes <strong>{{ saldo_puntos }} puntos</strong>. Necesitas al menos {{ cfg_puntos.minimo_puntos_canje }} para canjear.
                </div>
            </div>
            {% endif %}
        </div>

        <div class="col-lg-5 mb-4">
            <div class="sz-tienda-card">
                <div class="sz-tienda-card-header">
                    <h6 class="mb-0"><i class="fas fa-receipt mr-2"></i> Resumen del pedido</h6>
                </div>
                <div class="p-4">
                    <div id="checkoutItems"></div>

                    <div class="sz-total-row mt-3" id="rowDescuentoCupon" style="display:none;">
                        <span class="text-success"><i class="fas fa-tag mr-1"></i> Cupón</span>
                        <span class="text-success font-weight-bold" id="checkoutDescuentoCupon">-{{ _cfg.simbolo }}0.00</span>
                    </div>
                    <div class="sz-total-row" id="rowDescuentoPuntos" style="display:none;">
                        <span class="text-warning"><i class="fas fa-star mr-1"></i> Puntos</span>
                        <span class="text-warning font-weight-bold" id="checkoutDescuentoPuntos">-{{ _cfg.simbolo }}0.00</span>
                    </div>
                    <div class="sz-total-row sz-total-row--grande mt-2">
                        <span>Total</span>
                        <span id="checkoutTotal">{{ _cfg.simbolo }}0.00</span>
                    </div>

                    <div class="input-group mt-3">
                        <input type="text" id="inputCupon" class="form-control text-uppercase"
                               placeholder="Código de cupón" maxlength="50" autocomplete="off">
                        <div class="input-group-append">
                            <button class="btn btn-outline-secondary" id="btnAplicarCupon" type="button">
                                Aplicar
                            </button>
                        </div>
                    </div>
                    <div id="cuponMsg" class="mt-1 d-none" style="font-size:.85rem;"></div>

                    <button class="btn btn-sz btn-block mt-4" id="btnConfirmarPedido">
                        <i class="fas fa-check mr-2"></i> Confirmar pedido
                    </button>
                    <div id="checkoutError" class="alert alert-danger mt-3 d-none"></div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
$(document).ready(function () {
    var subtotal        = 0;
    var cuponCodigo     = '';
    var cuponDescuento  = 0;
    var puntosACanjear  = 0;
    var puntosDescuento = 0;
    const valorPunto    = {{ cfg_puntos.valor_punto ?? 0.5 }};

    function calcularSubtotal() {
        subtotal = 0;
        carrito.forEach(function (item) { subtotal += item.precio * item.cantidad; });
        return subtotal;
    }

    function actualizarTotales() {
        const totalFinal = Math.max(0, subtotal - cuponDescuento - puntosDescuento);
        $('#checkoutTotal').text(_SIMBOLO_ + totalFinal.toLocaleString('es-MX', {minimumFractionDigits: 2}));

        if (cuponDescuento > 0) {
            $('#checkoutDescuentoCupon').text('-' + _SIMBOLO_ + cuponDescuento.toLocaleString('es-MX', {minimumFractionDigits: 2}));
            $('#rowDescuentoCupon').show();
        } else {
            $('#rowDescuentoCupon').hide();
        }

        if (puntosDescuento > 0) {
            $('#checkoutDescuentoPuntos').text('-' + _SIMBOLO_ + puntosDescuento.toLocaleString('es-MX', {minimumFractionDigits: 2}));
            $('#rowDescuentoPuntos').show();
        } else {
            $('#rowDescuentoPuntos').hide();
        }
    }

    function renderResumen() {
        if (!carrito.length) { window.location.href = base_url('tienda/catalogo'); return; }
        let html = '';
        calcularSubtotal();
        carrito.forEach(function (item) {
            const sub = item.precio * item.cantidad;
            html += `<div class="sz-total-row">
                <span>${item.nombre} x${item.cantidad}</span>
                <span>${_SIMBOLO_}${sub.toFixed(2)}</span>
            </div>`;
        });
        $('#checkoutItems').html(html);
        actualizarTotales();
    }

    renderResumen();

    // ── Cupón ──────────────────────────────────────────────────
    $('#btnAplicarCupon').on('click', function () {
        const codigo = $('#inputCupon').val().trim().toUpperCase();
        const $msg   = $('#cuponMsg');
        if (!codigo) return;

        $(this).prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>');

        $.ajax({
            url: base_url('tienda/aplicar-cupon'), method: 'POST',
            data: { codigo: codigo, total: subtotal }, dataType: 'json',
            success: function (res) {
                $('#btnAplicarCupon').prop('disabled', false).text('Aplicar');
                if (res.response) {
                    cuponCodigo    = codigo;
                    cuponDescuento = res.result.descuento;
                    $msg.html('<span class="text-success"><i class="fas fa-check mr-1"></i>' + res.message + '</span>').removeClass('d-none');
                    $('#inputCupon').prop('disabled', true);
                    $('#btnAplicarCupon').text('Quitar').off('click').on('click', function () {
                        cuponCodigo    = '';
                        cuponDescuento = 0;
                        $('#inputCupon').val('').prop('disabled', false);
                        $msg.addClass('d-none');
                        $(this).text('Aplicar').off('click').on('click', arguments.callee);
                        actualizarTotales();
                    });
                } else {
                    $msg.html('<span class="text-danger"><i class="fas fa-times mr-1"></i>' + res.message + '</span>').removeClass('d-none');
                }
                actualizarTotales();
            },
            error: function () {
                $('#btnAplicarCupon').prop('disabled', false).text('Aplicar');
                $msg.html('<span class="text-danger">Error de conexión</span>').removeClass('d-none');
            }
        });
    });

    $('#inputCupon').on('input', function () { this.value = this.value.toUpperCase(); });

    // ── Canje de puntos ────────────────────────────────────────
    $('#btnAplicarPuntos').on('click', function () {
        const pts  = parseInt($('#inputPuntos').val()) || 0;
        const $msg = $('#puntosMsg');

        if (pts <= 0) {
            $msg.html('<span class="text-danger">Ingresa una cantidad válida</span>').removeClass('d-none');
            return;
        }

        puntosACanjear  = pts;
        puntosDescuento = Math.round(pts * valorPunto * 100) / 100;
        $msg.html('<span class="text-success"><i class="fas fa-check mr-1"></i>' + pts + ' puntos aplicados (-' + _SIMBOLO_ + puntosDescuento.toFixed(2) + ')</span>').removeClass('d-none');
        $('#inputPuntos').prop('disabled', true);
        $(this).text('Quitar').off('click').on('click', function () {
            puntosACanjear  = 0;
            puntosDescuento = 0;
            $('#inputPuntos').val('').prop('disabled', false);
            $msg.addClass('d-none');
            $(this).text('Canjear').off('click').on('click', arguments.callee);
            actualizarTotales();
        });
        actualizarTotales();
    });

    // ── CP / Colonia ───────────────────────────────────────────
    let cpTimer = null;
    $('#checkoutCP').on('input', function () {
        const cp = this.value.replace(/\D/g, '').slice(0, 5);
        this.value = cp;
        clearTimeout(cpTimer);
        if (cp.length < 5) {
            $('#checkoutColonia').html('<option value="">— Ingresa tu CP primero —</option>').prop('disabled', true);
            $('#rowCiudad').hide();
            return;
        }
        cpTimer = setTimeout(function () {
            $('#cpSpinner').show();
            $.getJSON(base_url('tienda/colonias?cp=' + cp), function (res) {
                if (res.colonias && res.colonias.length) {
                    let opts = '<option value="">Selecciona tu colonia</option>';
                    res.colonias.forEach(function (c) { opts += '<option value="' + c + '">' + c + '</option>'; });
                    $('#checkoutColonia').html(opts).prop('disabled', false);
                    $('#checkoutCiudad').val(res.ciudad || '');
                    $('#checkoutEstado').val(res.estado || '');
                    $('#rowCiudad').show();
                } else {
                    $('#checkoutColonia').html('<option value="">CP no encontrado</option>').prop('disabled', true);
                    $('#rowCiudad').hide();
                }
            }).fail(function () {
                $('#checkoutColonia').html('<option value="">Error al buscar CP</option>').prop('disabled', true);
            }).always(function () { $('#cpSpinner').hide(); });
        }, 600);
    });

    // ── Confirmar pedido ───────────────────────────────────────
    $('#btnConfirmarPedido').on('click', function () {
        const calle   = $('#checkoutCalle').val().trim();
        const cp      = $('#checkoutCP').val().trim();
        const colonia = $('#checkoutColonia').val();
        const ciudad  = $('#checkoutCiudad').val().trim();
        const estado  = $('#checkoutEstado').val().trim();

        if (!calle || !cp || !colonia) {
            $('#checkoutError').text('Completa la dirección: calle, CP y colonia son requeridos').removeClass('d-none');
            return;
        }
        const direccion = calle + ', Col. ' + colonia + ', CP ' + cp + (ciudad ? ', ' + ciudad : '') + (estado ? ', ' + estado : '');

        if (!carrito.length) { $('#checkoutError').text('Tu carrito está vacío').removeClass('d-none'); return; }

        $(this).prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-2"></i> Procesando...');
        $('#checkoutError').addClass('d-none');

        $.ajax({
            url: base_url('tienda/pedido'), method: 'POST',
            data: {
                items:          JSON.stringify(carrito.map(function (i) { return { id: i.id, nombre: i.nombre, precio: i.precio, cantidad: i.cantidad }; })),
                direccion:      direccion,
                cupon_codigo:   cuponCodigo,
                puntos_canjear: puntosACanjear,
            },
            dataType: 'json',
            success: function (res) {
                if (res.response) {
                    localStorage.removeItem('sz_carrito');
                    window.location.href = base_url('tienda/confirmacion/' + res.result.pedido_id);
                } else {
                    $('#checkoutError').text(res.message).removeClass('d-none');
                    $('#btnConfirmarPedido').prop('disabled', false)
                        .html('<i class="fas fa-check mr-2"></i> Confirmar pedido');
                }
            },
            error: function () {
                $('#checkoutError').text('Error de conexión').removeClass('d-none');
                $('#btnConfirmarPedido').prop('disabled', false)
                    .html('<i class="fas fa-check mr-2"></i> Confirmar pedido');
            }
        });
    });
});
</script>
{% endblock %}