{% extends "partials/new_layout.twig" %}

{% block content %}
<div class="sz-dashboard">

    <div class="sz-dash-header">
        <div>
            <h1 class="sz-dash-title">Historial de ventas</h1>
            <p class="sz-dash-sub">{{ total }} venta{{ total != 1 ? 's' : '' }} el {{ fecha|date('d/m/Y') }}</p>
        </div>
        <a href="{{ 'ventas'|url }}" class="btn btn-sz">
            <i class="fas fa-cash-register mr-2"></i> Ir a caja
        </a>
    </div>

    {# Filtro fecha #}
    <div class="sz-filtros animate-in mb-3" style="--delay:.05s">
        <form method="GET" action="{{ 'ventas/historial'|url }}" class="sz-filtros-form">
            <label style="font-size:.82rem;font-weight:500;color:var(--sz-ink);margin:0">Fecha:</label>
            <input type="date" name="fecha" value="{{ fecha }}" class="form-control" style="width:auto">
            <button type="submit" class="btn btn-sz">
                <i class="fas fa-search mr-1"></i> Ver
            </button>
        </form>
    </div>

    <div class="sz-dash-card animate-in" style="--delay:.1s">
        <div class="sz-card-header">
            <span class="sz-card-title"><i class="fas fa-receipt"></i> Ventas</span>
        </div>

        {% if datos|length > 0 %}
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Folio</th>
                        <th>Hora</th>
                        <th>Cajero</th>
                        <th>Cliente</th>
                        <th class="text-center">Pago</th>
                        <th class="text-center">Estado</th>
                        <th class="text-right">Total</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {% for venta in datos %}
                    <tr>
                        <td><code class="sz-codigo">#{{ venta.id|padLeft(5) }}</code></td>
                        <td>{{ venta.created_at|date('H:i') }}</td>
                        <td>{{ venta.usuario.nombre ?? '—' }}</td>
                        <td>{{ venta.cliente ? (venta.cliente.nombre ~ ' ' ~ venta.cliente.apellido) : 'Público general' }}</td>
                        <td class="text-center">
                            <span class="sz-turno-badge sz-pago--{{ venta.tipo }}">
                                {{ venta.tipo|capitalize }}
                            </span>
                        </td>
                        <td class="text-center">
                            {% if venta.estado == 'completada' %}
                                <span class="sz-stock-badge sz-badge--ok">Completada</span>
                            {% elseif venta.estado == 'cancelada' %}
                                <span class="sz-stock-badge sz-badge--danger">Cancelada</span>
                            {% else %}
                                <span class="sz-stock-badge sz-badge--warn">Pendiente</span>
                            {% endif %}
                        </td>
                        <td class="text-right sz-venta-monto">{{ _cfg.simbolo }}{{ venta.total|number_format(2, '.', ',') }}</td>
                        <td class="text-center">
                            <a href="{{ ('ventas/ticket/' ~ venta.id)|url }}" target="_blank"
                               class="btn btn-sm btn-outline-secondary mr-1" title="Ver ticket">
                                <i class="fas fa-receipt"></i>
                            </a>
                            {% if venta.estado == 'completada' %}
                            <button class="btn btn-sm btn-outline-danger btn-cancelar"
                                    data-id="{{ venta.id }}" title="Cancelar venta">
                                <i class="fas fa-ban"></i>
                            </button>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {% if total_pages > 1 %}
        <div class="sz-paginacion">
            {% if pagina > 1 %}
            <a href="{{ 'ventas/historial'|url }}?pagina={{ pagina - 1 }}&fecha={{ fecha }}" class="sz-page-btn"><i class="fas fa-chevron-left"></i></a>
            {% endif %}
            {% for i in 1..total_pages %}
                {% if i == pagina %}
                    <span class="sz-page-btn sz-page-btn--active">{{ i }}</span>
                {% elseif i == 1 or i == total_pages or (i >= pagina - 2 and i <= pagina + 2) %}
                    <a href="{{ 'ventas/historial'|url }}?pagina={{ i }}&fecha={{ fecha }}" class="sz-page-btn">{{ i }}</a>
                {% endif %}
            {% endfor %}
            {% if pagina < total_pages %}
            <a href="{{ 'ventas/historial'|url }}?pagina={{ pagina + 1 }}&fecha={{ fecha }}" class="sz-page-btn"><i class="fas fa-chevron-right"></i></a>
            {% endif %}
        </div>
        {% endif %}

        {% else %}
        <div class="sz-empty" style="padding:3rem">
            <i class="fas fa-receipt fa-2x mb-3 d-block" style="color:var(--sz-border)"></i>
            Sin ventas registradas para esta fecha
        </div>
        {% endif %}
    </div>
</div>

<div class="modal fade" id="modalCancelar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content sz-modal">
            <div class="modal-header">
                <h5 class="modal-title">Cancelar venta</h5>
                <button type="button" class="close" data-dismiss="modal"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                ¿Cancelar la venta <strong id="folioVenta"></strong>? El stock de los productos será revertido.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">No</button>
                <button type="button" class="btn btn-danger" id="btnConfirmarCancelar">
                    <i class="fas fa-ban mr-1"></i> Sí, cancelar
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
$(document).ready(function () {
    let idCancelar = null;

    $(document).on('click', '.btn-cancelar', function () {
        idCancelar = $(this).data('id');
        $('#folioVenta').text('#' + String(idCancelar).padStart(5, '0'));
        $('#modalCancelar').modal('show');
    });

    $('#btnConfirmarCancelar').on('click', function () {
        if (!idCancelar) return;
        $(this).prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Cancelando...');

        $.ajax({
            url:      base_url('ventas/cancelar'),
            method:   'POST',
            data:     { id: idCancelar },
            dataType: 'json',
            success: function (res) {
                if (res.response) { $('#modalCancelar').modal('hide'); location.reload(); }
                else alert(res.message);
            },
            complete: function () {
                $('#btnConfirmarCancelar').prop('disabled', false)
                    .html('<i class="fas fa-ban mr-1"></i> Sí, cancelar');
            }
        });
    });
});
</script>
{% endblock %}
