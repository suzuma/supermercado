<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<style>
    body { font-family: Arial, sans-serif; font-size: 11px; color: #0f1a0d; margin: 0; padding: 20px; }
    .header { border-bottom: 2px solid #1a6b2f; padding-bottom: 10px; margin-bottom: 16px; display: flex; justify-content: space-between; }
    .logo { font-size: 18px; font-weight: bold; color: #1a6b2f; }
    .logo span { color: #e85d04; }
    .titulo { font-size: 14px; font-weight: bold; color: #1a6b2f; margin-bottom: 12px; border-left: 3px solid #1a6b2f; padding-left: 8px; }
    .metricas { display: flex; gap: 12px; margin-bottom: 16px; }
    .metrica { flex: 1; background: #f5f7f4; border-radius: 6px; padding: 8px 12px; }
    .metrica-label { font-size: 9px; text-transform: uppercase; color: #6b7a6d; letter-spacing: .04em; }
    .metrica-valor { font-size: 16px; font-weight: bold; color: #1a6b2f; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
    th { background: #1a6b2f; color: #fff; font-size: 9px; text-transform: uppercase; letter-spacing: .04em; padding: 5px 7px; text-align: left; }
    td { padding: 5px 7px; border-bottom: 1px solid #dae3db; font-size: 10px; }
    tr:nth-child(even) td { background: #f8faf8; }
    .text-right { text-align: right; }
    .text-center { text-align: center; }
    .total-row td { font-weight: bold; background: #eaf3de; font-size: 11px; }
    .footer { margin-top: 20px; border-top: 1px solid #dae3db; padding-top: 8px; font-size: 9px; color: #6b7a6d; text-align: center; }
    .badge { display: inline-block; padding: 2px 7px; border-radius: 10px; font-size: 9px; font-weight: bold; }
    .badge-ok      { background: #f0faf6; color: #2d9e3a; }
    .badge-warn    { background: #fdf8ec; color: #b7820a; }
    .badge-danger  { background: #fdf2f2; color: #c0392b; }
</style>
</head>
<body>

<div class="header">
    <div>
        <div class="logo">Supermercado<span>Web</span></div>
        <div style="font-size:10px;color:#6b7a6d">Sistema de gestión integral</div>
    </div>
    <div style="text-align:right;font-size:10px;color:#6b7a6d">
        Generado: {{ "now"|date('d/m/Y H:i') }}<br>
        Período: {{ desde|date('d/m/Y') }} — {{ hasta|date('d/m/Y') }}
    </div>
</div>

<div class="titulo">Reporte de ventas</div>

<div class="metricas">
    <div class="metrica">
        <div class="metrica-label">Total ventas</div>
        <div class="metrica-valor">${{ ventas.total_monto|number_format(2, '.', ',') }}</div>
    </div>
    <div class="metrica">
        <div class="metrica-label">Transacciones</div>
        <div class="metrica-valor">{{ ventas.total_ventas }}</div>
    </div>
    <div class="metrica">
        <div class="metrica-label">Promedio</div>
        <div class="metrica-valor">${{ ventas.promedio|number_format(2, '.', ',') }}</div>
    </div>
</div>

<div class="titulo">Ventas por día</div>
<table>
    <thead>
        <tr>
            <th>Fecha</th>
            <th class="text-center">Ventas</th>
            <th class="text-right">Monto total</th>
            <th class="text-right">Promedio</th>
        </tr>
    </thead>
    <tbody>
        {% for row in ventas.datos %}
        <tr>
            <td>{{ row.fecha|date('d/m/Y') }}</td>
            <td class="text-center">{{ row.total_ventas }}</td>
            <td class="text-right">${{ row.monto_total|number_format(2, '.', ',') }}</td>
            <td class="text-right">${{ row.promedio|number_format(2, '.', ',') }}</td>
        </tr>
        {% endfor %}
    </tbody>
    <tfoot>
        <tr class="total-row">
            <td>TOTAL</td>
            <td class="text-center">{{ ventas.total_ventas }}</td>
            <td class="text-right">${{ ventas.total_monto|number_format(2, '.', ',') }}</td>
            <td></td>
        </tr>
    </tfoot>
</table>

<div class="titulo">Ventas por forma de pago</div>
<table>
    <thead><tr><th>Forma de pago</th><th class="text-center">Cantidad</th><th class="text-right">Monto</th></tr></thead>
    <tbody>
        {% for fp in forma_pago %}
        <tr>
            <td>{{ fp.tipo|capitalize }}</td>
            <td class="text-center">{{ fp.cantidad }}</td>
            <td class="text-right">${{ fp.monto|number_format(2, '.', ',') }}</td>
        </tr>
        {% endfor %}
    </tbody>
</table>

<div class="titulo">Productos más vendidos</div>
<table>
    <thead><tr><th>#</th><th>Producto</th><th>Categoría</th><th class="text-center">Unidades</th><th class="text-right">Ingreso</th></tr></thead>
    <tbody>
        {% for i, prod in mas_vendidos %}
        <tr>
            <td>{{ i + 1 }}</td>
            <td>{{ prod.nombre }}</td>
            <td>{{ prod.categoria }}</td>
            <td class="text-center">{{ prod.unidades_vendidas }}</td>
            <td class="text-right">${{ prod.ingreso_total|number_format(2, '.', ',') }}</td>
        </tr>
        {% endfor %}
    </tbody>
</table>

<div class="footer">Supermercado Web — Reporte generado automáticamente</div>
</body>
</html>
