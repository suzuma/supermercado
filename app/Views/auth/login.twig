<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ _cfg.negocio_nombre }} — Acceso</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:ital,wght@0,400;0,500;0,700&display=swap" rel="stylesheet">

    <link href="{{ 'fontawesome590/css/all.css'|public }}" rel="stylesheet">

    <style>
        :root {
            --green:      #1a6b2f;
            --green-dk:   #124d21;
            --green-lt:   rgba(26,107,47,.08);
            --accent:     #e85d04;
            --ink:        #0f1a0d;
            --paper:      #f5f7f4;
            --muted:      #6b7a6d;
            --border:     #dae3db;
            --card-bg:    #ffffff;
            --input-bg:   #f8faf8;
            --danger:     #c0392b;
            --danger-lt:  #fdf2f2;
            --danger-bd:  #f5c6c6;
            --shadow:     0 2px 8px rgba(15,26,13,.07), 0 16px 48px rgba(15,26,13,.10);
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        html, body { height: 100%; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--paper);
            min-height: 100vh;
            display: flex;
            align-items: stretch;
            overflow-x: hidden;
        }

        /* ── Fondo decorativo ───────────────────────────────── */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(var(--border) 1px, transparent 1px),
                linear-gradient(90deg, var(--border) 1px, transparent 1px);
            background-size: 48px 48px;
            opacity: .38;
            pointer-events: none;
        }

        /* ── Layout principal ───────────────────────────────── */
        .l-login {
            display: flex;
            width: 100%;
            min-height: 100vh;
            position: relative;
            z-index: 1;
        }

        /* ── Panel editorial izquierdo ─────────────────────── */
        .l-panel {
            display: none;
            flex: 1;
            background: linear-gradient(155deg, var(--green) 0%, var(--green-dk) 100%);
            flex-direction: column;
            justify-content: space-between;
            padding: 3rem;
            position: relative;
            overflow: hidden;
        }

        /* Círculos decorativos del panel */
        .l-panel::before {
            content: '';
            position: absolute;
            width: 560px;
            height: 560px;
            border-radius: 50%;
            border: 1px solid rgba(255,255,255,.08);
            top: -160px;
            left: -160px;
            pointer-events: none;
        }

        .l-panel::after {
            content: '';
            position: absolute;
            width: 360px;
            height: 360px;
            border-radius: 50%;
            background: rgba(232,93,4,.14);
            bottom: -100px;
            right: -100px;
            pointer-events: none;
        }

        .l-panel-top {
            display: flex;
            align-items: center;
            gap: .875rem;
            position: relative;
            z-index: 1;
        }

        .l-panel-top img {
            width: 44px;
            height: 44px;
            object-fit: contain;
            filter: brightness(0) invert(1);
        }

        .l-panel-top-name {
            font-family: 'DM Serif Display', serif;
            font-size: 1.1rem;
            color: #fff;
            letter-spacing: -.01em;
        }

        .l-panel-body {
            position: relative;
            z-index: 1;
        }

        .l-panel-headline {
            font-family: 'DM Serif Display', serif;
            font-size: clamp(2rem, 3vw, 2.8rem);
            color: #fff;
            line-height: 1.15;
            letter-spacing: -.03em;
            margin-bottom: 1.25rem;
        }

        .l-panel-headline span {
            color: var(--accent);
        }

        .l-panel-desc {
            font-size: .9rem;
            color: rgba(255,255,255,.65);
            line-height: 1.7;
            max-width: 300px;
            margin-bottom: 2.5rem;
        }

        .l-features {
            display: flex;
            flex-direction: column;
            gap: .875rem;
        }

        .l-feature {
            display: flex;
            align-items: center;
            gap: .875rem;
            color: rgba(255,255,255,.82);
            font-size: .85rem;
        }

        .l-feature-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: rgba(255,255,255,.1);
            border: 1px solid rgba(255,255,255,.12);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent);
            font-size: .78rem;
            flex-shrink: 0;
        }

        .l-panel-footer {
            font-size: .72rem;
            color: rgba(255,255,255,.35);
            position: relative;
            z-index: 1;
        }

        /* ── Panel del formulario ───────────────────────────── */
        .l-form-panel {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1.25rem;
        }

        .l-wrapper {
            width: 100%;
            max-width: 440px;
            animation: fadeUp .45s cubic-bezier(.22,.68,0,1.2) both;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Logo móvil */
        .l-mobile-brand {
            text-align: center;
            margin-bottom: 2.25rem;
        }

        .l-mobile-brand img {
            width: 80px;
            height: 80px;
            object-fit: contain;
            margin-bottom: .5rem;
        }

        .l-mobile-brand-name {
            font-family: 'DM Serif Display', serif;
            font-size: 1.25rem;
            color: var(--ink);
            letter-spacing: -.01em;
        }

        /* ── Tarjeta ────────────────────────────────────────── */
        .l-card {
            background: var(--card-bg);
            border-radius: 18px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow);
            padding: 2.5rem;
            position: relative;
            overflow: hidden;
        }

        /* Barra accent superior */
        .l-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--green) 0%, var(--accent) 100%);
        }

        .l-card-eyebrow {
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .14em;
            text-transform: uppercase;
            color: var(--green);
            margin-bottom: .625rem;
            display: flex;
            align-items: center;
            gap: .375rem;
        }

        .l-card-eyebrow::before {
            content: '';
            display: inline-block;
            width: 16px;
            height: 2px;
            background: var(--green);
            border-radius: 1px;
        }

        .l-card-title {
            font-family: 'DM Serif Display', serif;
            font-size: 2rem;
            color: var(--ink);
            letter-spacing: -.03em;
            line-height: 1.1;
            margin-bottom: .375rem;
        }

        .l-card-sub {
            font-size: .875rem;
            color: var(--muted);
            margin-bottom: 2rem;
        }

        /* ── Alerta de error (A11Y: role=alert + aria-live) ── */
        .l-alert {
            display: none;
            align-items: flex-start;
            gap: .75rem;
            background: var(--danger-lt);
            border: 1px solid var(--danger-bd);
            border-radius: 10px;
            padding: .875rem 1rem;
            margin-bottom: 1.5rem;
            font-size: .84rem;
            color: var(--danger);
        }

        .l-alert.is-visible { display: flex; }

        .l-alert-icon { flex-shrink: 0; margin-top: 1px; }

        /* ── Campos ─────────────────────────────────────────── */
        .l-field { margin-bottom: 1.375rem; }

        .l-field-label {
            display: block;
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: .07em;
            text-transform: uppercase;
            color: var(--ink);
            margin-bottom: 7px;
        }

        .l-field-wrap { position: relative; }

        .l-field-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .82rem;
            pointer-events: none;
            transition: color .18s;
        }

        .l-field-input {
            width: 100%;
            background: var(--input-bg);
            border: 1.5px solid var(--border);
            border-radius: 10px;
            padding: 12px 42px 12px 38px;
            font-family: 'DM Sans', sans-serif;
            font-size: .9rem;
            color: var(--ink);
            outline: none;
            transition: border-color .18s, box-shadow .18s, background .18s;
            -webkit-appearance: none;
        }

        .l-field-input::placeholder { color: #b0bdb2; }

        .l-field-input:focus {
            border-color: var(--green);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(26,107,47,.12);
        }

        /* Estado inválido */
        .l-field-input[aria-invalid="true"] {
            border-color: var(--danger);
            background: var(--danger-lt);
        }

        .l-field-input[aria-invalid="true"]:focus {
            box-shadow: 0 0 0 3px rgba(192,57,43,.12);
        }

        .l-field-wrap:focus-within .l-field-icon { color: var(--green); }

        /* Toggle ver contraseña */
        .l-toggle-pass {
            position: absolute;
            right: 11px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--muted);
            cursor: pointer;
            padding: 4px 6px;
            border-radius: 6px;
            font-size: .82rem;
            line-height: 1;
            transition: color .18s, background .18s;
        }

        .l-toggle-pass:hover,
        .l-toggle-pass:focus-visible {
            color: var(--green);
            background: var(--green-lt);
            outline: none;
        }

        /* Mensaje de error de campo (A11Y: role=alert) */
        .l-field-error {
            display: none;
            align-items: center;
            gap: .35rem;
            font-size: .75rem;
            color: var(--danger);
            margin-top: 6px;
            font-weight: 500;
        }

        .l-field-error.is-visible { display: flex; }

        /* ── Botón de acceso ────────────────────────────────── */
        .l-btn {
            width: 100%;
            background: var(--green);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 14px;
            font-family: 'DM Sans', sans-serif;
            font-size: .82rem;
            font-weight: 700;
            letter-spacing: .09em;
            text-transform: uppercase;
            cursor: pointer;
            margin-top: .375rem;
            position: relative;
            overflow: hidden;
            transition: background .2s, box-shadow .2s, transform .1s;
        }

        .l-btn:hover:not(:disabled) {
            background: var(--green-dk);
            box-shadow: 0 6px 20px rgba(26,107,47,.32);
        }

        .l-btn:active:not(:disabled) { transform: scale(.985); }

        .l-btn:focus-visible {
            outline: 3px solid var(--green);
            outline-offset: 2px;
        }

        .l-btn:disabled {
            opacity: .65;
            cursor: not-allowed;
        }

        .l-btn-text { transition: opacity .18s; }

        .l-btn-spinner {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity .18s;
        }

        .l-btn.is-loading .l-btn-text    { opacity: 0; }
        .l-btn.is-loading .l-btn-spinner { opacity: 1; }

        .l-spinner {
            width: 18px; height: 18px;
            border: 2px solid rgba(255,255,255,.35);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .7s linear infinite;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── Footer ─────────────────────────────────────────── */
        .l-footer {
            text-align: center;
            margin-top: 1.75rem;
            font-size: .72rem;
            color: var(--muted);
        }

        /* ── Responsivo ─────────────────────────────────────── */
        @media (min-width: 768px) {
            .l-panel       { display: flex; }
            .l-mobile-brand{ display: none; }
            .l-form-panel  { flex: 0 0 480px; }
        }

        @media (min-width: 1200px) {
            .l-form-panel { flex: 0 0 520px; }
            .l-card       { padding: 3rem; }
        }

        @media (max-width: 400px) {
            .l-form-panel { padding: 1.5rem 1rem; }
            .l-card       { padding: 1.75rem 1.25rem; }
            .l-card-title { font-size: 1.6rem; }
        }
    </style>
</head>
<body>

<div class="l-login">

    {# ── Panel editorial — solo desktop ──────────────────────── #}
    <aside class="l-panel" aria-hidden="true">

        <div class="l-panel-top">
            <img src="{{ ('images/' ~ _cfg.negocio_logo)|public }}"
                 alt="{{ _cfg.negocio_nombre }}"
                 width="44" height="44">
            <span class="l-panel-top-name">{{ _cfg.negocio_nombre }}</span>
        </div>

        <div class="l-panel-body">
            <h2 class="l-panel-headline">
                Gestión inteligente<br>para tu <span>supermercado</span>
            </h2>
            <p class="l-panel-desc">
                Control total de inventario, ventas, empleados y clientes desde un solo lugar.
            </p>
            <ul class="l-features" role="list">
                <li class="l-feature">
                    <span class="l-feature-icon"><i class="fas fa-boxes" aria-hidden="true"></i></span>
                    Control de inventario en tiempo real
                </li>
                <li class="l-feature">
                    <span class="l-feature-icon"><i class="fas fa-cash-register" aria-hidden="true"></i></span>
                    Punto de venta con promociones
                </li>
                <li class="l-feature">
                    <span class="l-feature-icon"><i class="fas fa-shopping-bag" aria-hidden="true"></i></span>
                    Tienda en línea integrada
                </li>
                <li class="l-feature">
                    <span class="l-feature-icon"><i class="fas fa-chart-bar" aria-hidden="true"></i></span>
                    Reportes y análisis de ventas
                </li>
            </ul>
        </div>

        <p class="l-panel-footer">SuZuMa &copy; {{ "now"|date("Y") }}</p>
    </aside>

    {# ── Panel del formulario ─────────────────────────────────── #}
    <main class="l-form-panel">
        <div class="l-wrapper">

            {# Logo — solo móvil #}
            <div class="l-mobile-brand" aria-hidden="true">
                <img src="{{ ('images/' ~ _cfg.negocio_logo)|public }}"
                     alt="{{ _cfg.negocio_nombre }}"
                     width="80" height="80">
                <p class="l-mobile-brand-name">{{ _cfg.negocio_nombre }}</p>
            </div>

            <div class="l-card">

                <p class="l-card-eyebrow">Acceso al sistema</p>
                <h1 class="l-card-title">Bienvenido</h1>
                <p class="l-card-sub">Ingresa tus credenciales para continuar</p>

                {# Alerta global — aria-live anuncia el mensaje al lector de pantalla #}
                <div class="l-alert"
                     id="alertError"
                     role="alert"
                     aria-live="assertive"
                     aria-atomic="true">
                    <i class="fas fa-exclamation-circle l-alert-icon" aria-hidden="true"></i>
                    <span id="alertMsg">Credenciales no válidas</span>
                </div>

                <form id="loginForm" novalidate aria-label="Formulario de acceso">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">

                    {# Campo email #}
                    <div class="l-field">
                        <label class="l-field-label" for="email">
                            Correo electrónico
                        </label>
                        <div class="l-field-wrap">
                            <i class="fas fa-envelope l-field-icon" aria-hidden="true"></i>
                            <input type="email"
                                   id="email"
                                   name="email"
                                   class="l-field-input"
                                   placeholder="usuario@ejemplo.com"
                                   autocomplete="email"
                                   aria-required="true"
                                   aria-invalid="false"
                                   aria-describedby="emailError">
                        </div>
                        <p class="l-field-error"
                           id="emailError"
                           role="alert">
                            <i class="fas fa-times-circle" aria-hidden="true"></i>
                            Ingresa un correo electrónico válido
                        </p>
                    </div>

                    {# Campo contraseña #}
                    <div class="l-field">
                        <label class="l-field-label" for="password">
                            Contraseña
                        </label>
                        <div class="l-field-wrap">
                            <i class="fas fa-lock l-field-icon" aria-hidden="true"></i>
                            <input type="password"
                                   id="password"
                                   name="password"
                                   class="l-field-input"
                                   placeholder="••••••••"
                                   autocomplete="current-password"
                                   aria-required="true"
                                   aria-invalid="false"
                                   aria-describedby="passError">
                            <button type="button"
                                    class="l-toggle-pass"
                                    id="togglePass"
                                    aria-label="Mostrar contraseña"
                                    aria-pressed="false">
                                <i class="fas fa-eye" id="eyeIcon" aria-hidden="true"></i>
                            </button>
                        </div>
                        <p class="l-field-error"
                           id="passError"
                           role="alert">
                            <i class="fas fa-times-circle" aria-hidden="true"></i>
                            La contraseña es requerida
                        </p>
                    </div>

                    <button type="submit"
                            class="l-btn"
                            id="btnLogin"
                            aria-label="Iniciar sesión">
                        <span class="l-btn-text">Iniciar sesión</span>
                        <span class="l-btn-spinner" aria-hidden="true">
                            <span class="l-spinner"></span>
                        </span>
                    </button>

                </form>

            </div>

            <p class="l-footer">
                Desarrollado por SuZuMa &copy; {{ "now"|date("Y") }}
            </p>

        </div>
    </main>

</div>

<script src="{{ 'js/jquery3-4-1.js'|public }}"></script>
<script src="{{ 'bower_components/jquery.form.min/index.js'|public }}"></script>

<script>
    const _BASE_URL_ = {{ base_url|json_encode|raw }};
    function base_url(url) { return _BASE_URL_ + (url || ''); }
    function redirect(url) { window.location.href = base_url(url); }

    /* ── Toggle contraseña ──────────────────────────────────── */
    document.getElementById('togglePass').addEventListener('click', function () {
        const input   = document.getElementById('password');
        const icon    = document.getElementById('eyeIcon');
        const visible = input.type === 'password';

        input.type = visible ? 'text' : 'password';
        this.setAttribute('aria-label',   visible ? 'Ocultar contraseña' : 'Mostrar contraseña');
        this.setAttribute('aria-pressed', visible ? 'true' : 'false');
        icon.classList.toggle('fa-eye',       !visible);
        icon.classList.toggle('fa-eye-slash',  visible);
    });

    /* ── Formulario ─────────────────────────────────────────── */
    $(document).ready(function () {

        function setFieldError(inputId, errorId, isInvalid) {
            const input = document.getElementById(inputId);
            const error = document.getElementById(errorId);
            input.setAttribute('aria-invalid', isInvalid ? 'true' : 'false');
            error.classList.toggle('is-visible', isInvalid);
        }

        function clearErrors() {
            setFieldError('email',    'emailError', false);
            setFieldError('password', 'passError',  false);
            $('#alertError').removeClass('is-visible');
        }

        $('#loginForm').on('submit', function (e) {
            e.preventDefault();

            const email = $('#email').val().trim();
            const pass  = $('#password').val().trim();
            let   valid = true;

            clearErrors();

            if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
                setFieldError('email', 'emailError', true);
                valid = false;
            }
            if (!pass) {
                setFieldError('password', 'passError', true);
                valid = false;
            }
            if (!valid) {
                document.querySelector('[aria-invalid="true"]').focus();
                return;
            }

            const btn = document.getElementById('btnLogin');
            btn.classList.add('is-loading');
            btn.disabled = true;

            $.ajax({
                url:         base_url('auth/signin'),
                method:      'POST',
                data:        $(this).serialize(),
                contentType: 'application/x-www-form-urlencoded',
                dataType:    'json',
                success: function (data) {
                    if (data.response) {
                        redirect(data.href || 'home');
                    } else {
                        btn.classList.remove('is-loading');
                        btn.disabled = false;
                        $('#alertMsg').text(data.message || 'Credenciales no válidas');
                        $('#alertError').addClass('is-visible');
                    }
                },
                error: function () {
                    btn.classList.remove('is-loading');
                    btn.disabled = false;
                    $('#alertMsg').text('Error de conexión. Intenta de nuevo.');
                    $('#alertError').addClass('is-visible');
                }
            });
        });
    });
</script>

</body>
</html>
