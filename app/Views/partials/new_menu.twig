{#
    autor: Noe Cazarez Camargo
    descripcion: SIDEBAR DE NAVEGACION — visible segun permisos RBAC
#}

<aside class="sz-sidebar" id="szSidebar">

    {# Logo / marca #}
    <div class="sz-sidebar-brand">
        <img src="{{ ('images/' ~ _cfg.negocio_logo)|public }}"
             alt="{{ _cfg.negocio_nombre }}"
             class="sz-sidebar-logo-img">
        <span class="sz-sidebar-logo-text">{{ _cfg.negocio_nombre }}</span>
        <button class="sz-sidebar-toggle" id="sidebarToggle" title="Expandir">
            <i class="fas fa-bars"></i>
        </button>
    </div>

    {# Perfil del usuario #}
    <div class="sz-sidebar-profile">
        <div class="sz-avatar">{{ user().nombre|slice(0,1)|upper }}{{ user().apellido|slice(0,1)|upper }}</div>
        <div class="sz-profile-info">
            <span class="sz-profile-name">{{ user().nombre }} {{ user().apellido }}</span>
            <span class="sz-profile-role">{{ user().rol }}</span>
        </div>
    </div>

    {# Navegación #}
    <nav class="sz-nav">

        {# Dashboard — todos los roles #}
        <a href="{{ 'home'|url }}" class="sz-nav-item {% if _route == 'home' %}sz-nav-item--active{% endif %}">
            <i class="fas fa-th-large"></i>
            <span>Dashboard</span>
        </a>

        {# Grupo: Operaciones #}
        {% if can('inventario.ver') or can('proveedores.ver') or can('clientes.ver') or can('ventas.ver') or can('corte_caja.ver') or can('devoluciones.ver') or can('promociones.ver') %}
        <div class="sz-nav-group">
            <span class="sz-nav-label">Operaciones</span>

            {% if can('inventario.ver') %}
            <a href="{{ 'inventario'|url }}" class="sz-nav-item {% if _route == 'inventario' %}sz-nav-item--active{% endif %}">
                <i class="fas fa-boxes"></i>
                <span>Inventario</span>
                {% if _cfg.stock_bajo_total > 0 %}
                <span class="sz-nav-badge" title="{{ _cfg.stock_bajo_total }} producto{{ _cfg.stock_bajo_total != 1 ? 's' : '' }} con stock bajo">
                    {{ _cfg.stock_bajo_total }}
                </span>
                {% endif %}
            </a>
            {% endif %}

            {% if can('proveedores.ver') %}
            <a href="{{ 'proveedores'|url }}" class="sz-nav-item {% if _route == 'proveedores' %}sz-nav-item--active{% endif %}">
                <i class="fas fa-truck-loading"></i>
                <span>Proveedores</span>
            </a>
            {% endif %}

            {% if can('clientes.ver') %}
            <a href="{{ 'clientes'|url }}" class="sz-nav-item {% if _route == 'clientes' %}sz-nav-item--active{% endif %}">
                <i class="fas fa-users"></i>
                <span>Clientes</span>
            </a>
            {% endif %}

            {% if can('ventas.ver') %}
            <a href="{{ 'ventas'|url }}" class="sz-nav-item {% if _route == 'ventas' %}sz-nav-item--active{% endif %}">
                <i class="fas fa-cash-register"></i>
                <span>Ventas</span>
            </a>
            {% endif %}

            {% if can('corte_caja.ver') %}
            <a href="{{ 'corte-caja'|url }}" class="sz-nav-item {% if _route == 'corte-caja' %}sz-nav-item--active{% endif %}">
                <i class="fas fa-calculator"></i>
                <span>Corte de caja</span>
            </a>
            {% endif %}

            {% if can('devoluciones.ver') %}
            <a href="{{ 'devoluciones'|url }}" class="sz-nav-item {% if _route == 'devoluciones' %}sz-nav-item--active{% endif %}">
                <i class="fas fa-undo"></i>
                <span>Devoluciones</span>
            </a>
            {% endif %}

            {% if can('promociones.ver') %}
            <a href="{{ 'promociones'|url }}" class="sz-nav-item {% if _route == 'promociones' %}sz-nav-item--active{% endif %}">
                <i class="fas fa-tags"></i>
                <span>Promociones</span>
            </a>
            {% endif %}

        </div>
        {% endif %}

        {# Pedidos en línea #}
        {% if can('pedidos.ver') %}
        <a href="{{ 'pedidos'|url }}" class="sz-nav-item {% if _route == 'pedidos' %}sz-nav-item--active{% endif %}">
            <i class="fas fa-shopping-bag"></i>
            <span>Pedidos en línea</span>
            {% if _cfg.pedidos_pendientes_total > 0 %}
            <span class="sz-nav-badge" title="{{ _cfg.pedidos_pendientes_total }} pedido{{ _cfg.pedidos_pendientes_total != 1 ? 's' : '' }} pendiente{{ _cfg.pedidos_pendientes_total != 1 ? 's' : '' }}">
                {{ _cfg.pedidos_pendientes_total }}
            </span>
            {% endif %}
        </a>
        {% endif %}

        {# Grupo: Análisis #}
        {% if can('reportes.ver') %}
        <div class="sz-nav-group">
            <span class="sz-nav-label">Análisis</span>
            <a href="{{ 'reportes'|url }}" class="sz-nav-item {% if _route == 'reportes' %}sz-nav-item--active{% endif %}">
                <i class="fas fa-chart-bar"></i>
                <span>Reportes</span>
            </a>
        </div>
        {% endif %}

        {# Grupo: Administración #}
        {% if can('empleados.ver') or can('configuracion.ver') or can('cupones.ver') or can('auditoria.ver') %}
        <div class="sz-nav-group">
            <span class="sz-nav-label">Administración</span>

            {% if can('empleados.ver') %}
            <a href="{{ 'empleados'|url }}" class="sz-nav-item {% if _route == 'empleados' %}sz-nav-item--active{% endif %}">
                <i class="fas fa-id-badge"></i>
                <span>Empleados</span>
            </a>
            {% endif %}

            {% if can('configuracion.ver') %}
            <a href="{{ 'configuracion'|url }}" class="sz-nav-item {% if _route == 'configuracion' %}sz-nav-item--active{% endif %}">
                <i class="fas fa-cog"></i>
                <span>Configuración</span>
            </a>
            {% endif %}

            {% if isAdmin() %}
            <a href="{{ 'permisos'|url }}" class="sz-nav-item {% if _route == 'permisos' %}sz-nav-item--active{% endif %}">
                <i class="fas fa-shield-alt"></i>
                <span>Permisos</span>
            </a>
            {% endif %}

            {% if can('cupones.ver') %}
            <a href="{{ 'cupones'|url }}" class="sz-nav-item {% if _route == 'cupones' %}sz-nav-item--active{% endif %}">
                <i class="fas fa-ticket-alt"></i>
                <span>Cupones</span>
            </a>
            {% endif %}

            {% if can('auditoria.ver') %}
            <a href="{{ 'auditoria'|url }}" class="sz-nav-item {% if _route == 'auditoria' %}sz-nav-item--active{% endif %}">
                <i class="fas fa-clipboard-list"></i>
                <span>Auditoría</span>
            </a>
            {% endif %}

        </div>
        {% endif %}

    </nav>

    {# Cerrar sesión #}
    <div class="sz-sidebar-footer">
        <a href="{{ 'auth/signout'|url }}" class="sz-nav-item sz-nav-item--signout">
            <i class="fas fa-sign-out-alt"></i>
            <span>Cerrar sesión</span>
        </a>
    </div>

</aside>

{# Overlay para móvil #}
<div class="sz-sidebar-overlay" id="sidebarOverlay"></div>
