{% extends "partials/new_layout.twig" %}


{% block content %}
<div class="sz-dashboard">

    <div class="sz-dash-header">
        <div>
            <h1 class="sz-dash-title">{{ title }}</h1>
            <p class="sz-dash-sub">
                <a href="{{ 'promociones'|url }}" class="sz-back-link">
                    <i class="fas fa-arrow-left mr-1"></i> Volver
                </a>
            </p>
        </div>
    </div>

    <form id="formPromocion">
        <input type="hidden" name="id" value="{{ model.id }}">
        <div class="row">
            <div class="col-lg-8">
                <div class="sz-dash-card animate-in" style="--delay:.05s">
                    <div class="sz-card-header">
                        <span class="sz-card-title"><i class="fas fa-tag"></i> Datos de la promoción</span>
                    </div>
                    <div class="p-4">

                        <div class="form-group">
                            <label>Nombre de la promoción *</label>
                            <input type="text" class="form-control" name="nombre"
                                   value="{{ model.nombre }}" placeholder="Ej: 20% off en Manzanas" required>
                        </div>

                        <div class="form-group">
                            <label>Producto *</label>
                            <select class="form-control" name="producto_id" required id="selectProducto">
                                <option value="">— Seleccionar producto —</option>
                                {% for producto in productos %}
                                <option value="{{ producto.id }}"
                                        data-precio="{{ producto.precio_venta }}"
                                        {% if model.producto_id == producto.id %}selected{% endif %}>
                                    {{ producto.nombre }} — {{ _cfg.simbolo }}{{ producto.precio_venta|number_format(2, '.', ',') }}
                                </option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Tipo de promoción *</label>
                            <select class="form-control" name="tipo" id="selectTipo" required>
                                <option value="porcentaje"       {% if model.tipo == 'porcentaje' %}selected{% endif %}>Descuento por porcentaje</option>
                                <option value="precio_fijo"      {% if model.tipo == 'precio_fijo' %}selected{% endif %}>Precio especial fijo</option>
                                <option value="2x1"              {% if model.tipo == '2x1' %}selected{% endif %}>2x1</option>
                                <option value="cantidad_minima"  {% if model.tipo == 'cantidad_minima' %}selected{% endif %}>Descuento por cantidad mínima</option>
                            </select>
                        </div>

                        {# Campos dinámicos por tipo #}
                        <div id="campoValor" class="form-group">
                            <label id="labelValor">Porcentaje de descuento *</label>
                            <div class="input-group">
                                <input type="number" class="form-control" name="valor" id="inputValor"
                                       value="{{ model.valor }}" min="0" step="0.01"
                                       placeholder="Ej: 20">
                                <div class="input-group-append">
                                    <span class="input-group-text sz-input-prefix" id="sufijo">%</span>
                                </div>
                            </div>
                        </div>

                        <div id="campoCantidadMin" class="form-group" style="display:none">
                            <label>Cantidad mínima para aplicar *</label>
                            <input type="number" class="form-control" name="cantidad_min"
                                   value="{{ model.cantidad_min ?? 1 }}" min="1" placeholder="Ej: 3">
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Fecha inicio *</label>
                                    <input type="date" class="form-control" name="fecha_inicio"
                                           value="{{ model.fecha_inicio ?? "now"|date('Y-m-d') }}" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Fecha fin *</label>
                                    <input type="date" class="form-control" name="fecha_fin"
                                           value="{{ model.fecha_fin ?? "now"|date('Y-m-d') }}" required>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                {# Preview de la promoción #}
                <div class="sz-dash-card animate-in mb-3" style="--delay:.1s">
                    <div class="sz-card-header">
                        <span class="sz-card-title"><i class="fas fa-eye"></i> Vista previa</span>
                    </div>
                    <div class="p-4 text-center">
                        <div class="sz-promo-preview" id="promoPreview">
                            <div class="sz-promo-preview-precio">
                                <span class="sz-promo-precio-original" id="precioOriginalPreview">—</span>
                                <span class="sz-promo-precio-final" id="precioFinalPreview">—</span>
                            </div>
                            <div class="sz-promo-badge mt-2" id="promoBadgePreview">Sin configurar</div>
                        </div>
                    </div>
                </div>

                <div class="sz-dash-card animate-in" style="--delay:.15s">
                    <div class="p-3">
                        <button type="submit" class="btn btn-sz btn-block" id="btnGuardar">
                            <i class="fas fa-save mr-2"></i> Guardar promoción
                        </button>
                        <a href="{{ 'promociones'|url }}" class="btn btn-outline-secondary btn-block mt-2">
                            Cancelar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
<script>
$(document).ready(function () {
    const simbolo = '{{ _cfg.simbolo }}';

    function actualizarCampos() {
        const tipo = $('#selectTipo').val();

        $('#campoValor').show();
        $('#campoCantidadMin').hide();

        switch (tipo) {
            case 'porcentaje':
                $('#labelValor').text('Porcentaje de descuento *');
                $('#sufijo').text('%');
                $('#inputValor').attr('placeholder', 'Ej: 20');
                break;
            case 'precio_fijo':
                $('#labelValor').text('Precio especial *');
                $('#sufijo').text(simbolo);
                $('#inputValor').attr('placeholder', 'Ej: 15.00');
                break;
            case '2x1':
                $('#campoValor').hide();
                break;
            case 'cantidad_minima':
                $('#labelValor').text('Porcentaje de descuento *');
                $('#sufijo').text('%');
                $('#campoCantidadMin').show();
                break;
        }

        actualizarPreview();
    }

    function actualizarPreview() {
        const tipo       = $('#selectTipo').val();
        const valor      = parseFloat($('#inputValor').val()) || 0;
        const cantMin    = parseInt($('[name="cantidad_min"]').val()) || 1;
        const precioOpt  = $('#selectProducto option:selected').data('precio');
        const precio     = parseFloat(precioOpt) || 0;

        let precioFinal = precio;
        let badge       = '';

        switch (tipo) {
            case 'porcentaje':
                precioFinal = precio * (1 - valor / 100);
                badge = `<span class="sz-promo-badge sz-promo--pct">${valor}% off</span>`;
                break;
            case 'precio_fijo':
                precioFinal = valor;
                badge = `<span class="sz-promo-badge sz-promo--fijo">Precio especial</span>`;
                break;
            case '2x1':
                badge = `<span class="sz-promo-badge sz-promo--2x1">2×1</span>`;
                break;
            case 'cantidad_minima':
                badge = `<span class="sz-promo-badge sz-promo--cant">${valor}% off x${cantMin}+</span>`;
                break;
        }

        if (precio > 0) {
            $('#precioOriginalPreview').html(precio !== precioFinal
                ? `<del>${simbolo}${precio.toFixed(2)}</del>`
                : `${simbolo}${precio.toFixed(2)}`);
            $('#precioFinalPreview').text(tipo === '2x1' ? `2×${simbolo}${precio.toFixed(2)}` : `${simbolo}${precioFinal.toFixed(2)}`);
        }

        $('#promoBadgePreview').html(badge || 'Sin configurar');
    }

    $('#selectTipo').on('change', actualizarCampos);
    $('#selectProducto, #inputValor, [name="cantidad_min"]').on('change input', actualizarPreview);

    actualizarCampos();

    $('#formPromocion').on('submit', function (e) {
        e.preventDefault();
        $('#btnGuardar').prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-2"></i> Guardando...');

        $.ajax({
            url: base_url('promociones/guardar'), method: 'POST',
            data: $(this).serialize(), dataType: 'json',
            success: function (res) {
                if (res.response) redirect(res.href || 'promociones');
                else {
                    alert(res.message || 'Error al guardar');
                    $('#btnGuardar').prop('disabled', false).html('<i class="fas fa-save mr-2"></i> Guardar promoción');
                }
            },
            error: function () {
                alert('Error de conexión');
                $('#btnGuardar').prop('disabled', false).html('<i class="fas fa-save mr-2"></i> Guardar promoción');
            }
        });
    });
});
</script>
{% endblock %}
