<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Orden de entrega #{{ pedido.id|padLeft(5) }}</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Arial, sans-serif; font-size: 13px; color: #000; padding: 20px; }
        .header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #1a6b2f; padding-bottom: 12px; margin-bottom: 16px; }
        .logo { font-size: 20px; font-weight: bold; color: #1a6b2f; }
        .logo span { color: #e85d04; }
        .folio { text-align: right; }
        .folio h2 { font-size: 18px; color: #1a6b2f; }
        .folio p  { font-size: 11px; color: #666; }
        .section { margin-bottom: 16px; }
        .section-title { font-size: 11px; font-weight: bold; letter-spacing: .06em; text-transform: uppercase; color: #666; border-bottom: 1px solid #dae3db; padding-bottom: 4px; margin-bottom: 8px; }
        .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        .info-item label { font-size: 10px; color: #888; display: block; }
        .info-item span  { font-weight: 500; }
        table { width: 100%; border-collapse: collapse; margin-top: 8px; }
        th { background: #f5f7f4; font-size: 11px; text-transform: uppercase; letter-spacing: .04em; padding: 6px 8px; text-align: left; border: 1px solid #dae3db; }
        td { padding: 6px 8px; border: 1px solid #dae3db; font-size: 12px; }
        .text-right { text-align: right; }
        .total-row td { font-weight: bold; background: #f5f7f4; font-size: 13px; }
        .estado { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: bold; }
        .estado--pendiente  { background: #fdf8ec; color: #b7820a; }
        .estado--confirmado { background: #e6f1fb; color: #185FA5; }
        .estado--enviado    { background: #EEEDFE; color: #3C3489; }
        .estado--entregado  { background: #f0faf6; color: #2d9e3a; }
        .firma-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 40px; }
        .firma-box { border-top: 1px solid #000; padding-top: 4px; font-size: 11px; text-align: center; color: #666; }
        .no-print { margin-top: 20px; text-align: center; }
        @media print { .no-print { display: none; } }
    </style>
</head>
<body>

<div class="header">
    <div>
        <div class="logo">Supermercado<span>Web</span></div>
        <div style="font-size:11px;color:#666;margin-top:4px">Sistema de gestión integral</div>
    </div>
    <div class="folio">
        <h2>Orden de entrega</h2>
        <p>Folio: #{{ pedido.id|padLeft(5) }}</p>
        <p>Fecha: {{ "now"|date('d/m/Y H:i') }}</p>
    </div>
</div>

<div class="section">
    <div class="section-title">Información del pedido</div>
    <div class="info-grid">
        <div class="info-item">
            <label>Fecha del pedido</label>
            <span>{{ pedido.created_at|date('d/m/Y H:i') }}</span>
        </div>
        <div class="info-item">
            <label>Estado</label>
            <span class="estado estado--{{ pedido.estado }}">{{ pedido.estado|capitalize }}</span>
        </div>
        {% if pedido.fecha_entrega %}
        <div class="info-item">
            <label>Entrega estimada</label>
            <span>{{ pedido.fecha_entrega|date('d/m/Y H:i') }}</span>
        </div>
        {% endif %}
        <div class="info-item">
            <label>Total</label>
            <span style="color:#1a6b2f;font-size:15px">${{ pedido.total|number_format(2, '.', ',') }}</span>
        </div>
    </div>
</div>

<div class="section">
    <div class="section-title">Datos del cliente</div>
    <div class="info-grid">
        <div class="info-item">
            <label>Nombre</label>
            <span>{{ pedido.cliente ? (pedido.cliente.nombre ~ ' ' ~ pedido.cliente.apellido) : '—' }}</span>
        </div>
        <div class="info-item">
            <label>Teléfono</label>
            <span>{{ pedido.cliente.telefono ?? '—' }}</span>
        </div>
        <div class="info-item" style="grid-column:1/-1">
            <label>Dirección de entrega</label>
            <span>{{ pedido.direccion_entrega }}</span>
        </div>
    </div>
</div>

{% if pedido.usuario %}
<div class="section">
    <div class="section-title">Repartidor asignado</div>
    <div class="info-grid">
        <div class="info-item">
            <label>Nombre</label>
            <span>{{ pedido.usuario.nombre }} {{ pedido.usuario.apellido }}</span>
        </div>
        <div class="info-item">
            <label>Correo</label>
            <span>{{ pedido.usuario.email }}</span>
        </div>
    </div>
</div>
{% endif %}

<div class="section">
    <div class="section-title">Detalle de productos</div>
    <table>
        <thead>
            <tr>
                <th>Producto</th>
                <th class="text-right">Cantidad</th>
                <th class="text-right">Precio u.</th>
                <th class="text-right">Subtotal</th>
            </tr>
        </thead>
        <tbody>
            {% for detalle in pedido.detalles %}
            <tr>
                <td>{{ detalle.producto.nombre }}</td>
                <td class="text-right">{{ detalle.cantidad }}</td>
                <td class="text-right">${{ detalle.precio_unitario|number_format(2, '.', ',') }}</td>
                <td class="text-right">${{ detalle.subtotal|number_format(2, '.', ',') }}</td>
            </tr>
            {% endfor %}
        </tbody>
        <tfoot>
            <tr class="total-row">
                <td colspan="3" class="text-right">TOTAL</td>
                <td class="text-right">${{ pedido.total|number_format(2, '.', ',') }}</td>
            </tr>
        </tfoot>
    </table>
</div>

<div class="firma-grid">
    <div class="firma-box">Firma del repartidor</div>
    <div class="firma-box">Firma del cliente / Recibió</div>
</div>

<div class="no-print">
    <button onclick="window.print()" style="padding:8px 20px;cursor:pointer;margin-right:8px;background:#1a6b2f;color:#fff;border:none;border-radius:6px">
        <i class="fas fa-print mr-1"></i> Imprimir
    </button>
    <button onclick="window.close()" style="padding:8px 20px;cursor:pointer;background:none;border:1px solid #dae3db;border-radius:6px">
        Cerrar
    </button>
</div>

<script>window.onload = function() { window.print(); }</script>
</body>
</html>
