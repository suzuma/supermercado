{% extends "partials/new_layout.twig" %}

{% block content %}
<div class="sz-dashboard">

    <div class="sz-dash-header">
        <div>
            <h1 class="sz-dash-title">Pedidos en línea</h1>
            <p class="sz-dash-sub">{{ total }} pedido{{ total != 1 ? 's' : '' }} encontrado{{ total != 1 ? 's' : '' }}</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a href="{{ 'pedidos/kanban'|url }}" class="btn btn-outline-secondary">
                <i class="fas fa-columns mr-1"></i> Vista Kanban
            </a>
            <a href="{{ 'pedidos/exportar'|url }}{% if estado or fecha_desde or fecha_hasta %}?{% endif %}{{ estado ? 'estado=' ~ estado : '' }}{{ (estado and (fecha_desde or fecha_hasta)) ? '&' : '' }}{{ fecha_desde ? 'fecha_desde=' ~ fecha_desde : '' }}{{ (fecha_desde and fecha_hasta) ? '&' : '' }}{{ fecha_hasta ? 'fecha_hasta=' ~ fecha_hasta : '' }}"
               class="btn btn-outline-secondary">
                <i class="fas fa-file-csv mr-1"></i> Exportar CSV
            </a>
        </div>
    </div>

    {# Filtros #}
    <div class="sz-filtros animate-in" style="--delay:.05s">
        <div class="sz-estados-filter">
            <a href="{{ 'pedidos'|url }}{{ fecha_desde or fecha_hasta ? '?' : '' }}{{ fecha_desde ? 'fecha_desde=' ~ fecha_desde : '' }}{{ (fecha_desde and fecha_hasta) ? '&' : '' }}{{ fecha_hasta ? 'fecha_hasta=' ~ fecha_hasta : '' }}"
               class="sz-estado-tab {% if not estado %}sz-estado-tab--active{% endif %}">Todos</a>
            {% for est, icon in {'pendiente': 'clock', 'confirmado': 'check', 'enviado': 'truck', 'entregado': 'box-open', 'cancelado': 'ban'} %}
            <a href="{{ 'pedidos'|url }}?estado={{ est }}{{ fecha_desde ? '&fecha_desde=' ~ fecha_desde : '' }}{{ fecha_hasta ? '&fecha_hasta=' ~ fecha_hasta : '' }}"
               class="sz-estado-tab sz-estado-tab--{{ est }} {% if estado == est %}sz-estado-tab--active{% endif %}">
                <i class="fas fa-{{ icon }} mr-1"></i> {{ est|capitalize }}
            </a>
            {% endfor %}
        </div>

        {# Filtro de fechas #}
        <form method="GET" action="{{ 'pedidos'|url }}" class="d-flex align-items-center gap-2 mt-2 flex-wrap" id="formFechas">
            {% if estado %}<input type="hidden" name="estado" value="{{ estado }}">{% endif %}
            <div class="d-flex align-items-center gap-1">
                <label class="mb-0 text-muted" style="font-size:.85rem;white-space:nowrap">Desde</label>
                <input type="date" name="fecha_desde" class="form-control form-control-sm" style="width:150px"
                       value="{{ fecha_desde ?? '' }}">
            </div>
            <div class="d-flex align-items-center gap-1">
                <label class="mb-0 text-muted" style="font-size:.85rem;white-space:nowrap">Hasta</label>
                <input type="date" name="fecha_hasta" class="form-control form-control-sm" style="width:150px"
                       value="{{ fecha_hasta ?? '' }}">
            </div>
            <button type="submit" class="btn btn-sz btn-sm"><i class="fas fa-filter mr-1"></i> Filtrar</button>
            {% if fecha_desde or fecha_hasta %}
            <a href="{{ 'pedidos'|url }}{{ estado ? '?estado=' ~ estado : '' }}" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-times mr-1"></i> Limpiar fechas
            </a>
            {% endif %}
        </form>
    </div>

    {# Tabla de pedidos #}
    <div class="sz-dash-card animate-in" style="--delay:.1s">
        <div class="sz-card-header">
            <span class="sz-card-title"><i class="fas fa-shopping-bag"></i> Lista de pedidos</span>
        </div>

        {% if datos|length > 0 %}
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Folio</th>
                        <th>Cliente</th>
                        <th>Repartidor</th>
                        <th class="text-center">Estado</th>
                        <th class="text-right">Total</th>
                        <th>Fecha</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {% for pedido in datos %}
                    <tr>
                        <td><code class="sz-codigo">#{{ pedido.id|padLeft(5) }}</code></td>
                        <td>
                            {% if pedido.cliente %}
                            <div class="sz-emp-info">
                                <div class="sz-emp-avatar" style="width:32px;height:32px;font-size:.7rem">
                                    {{ pedido.cliente.nombre|slice(0,1)|upper }}{{ pedido.cliente.apellido|slice(0,1)|upper }}
                                </div>
                                <div>
                                    <span class="sz-prod-nombre">{{ pedido.cliente.nombre }} {{ pedido.cliente.apellido }}</span>
                                    <small class="sz-prod-desc">{{ pedido.cliente.telefono ?? '' }}</small>
                                </div>
                            </div>
                            {% else %}
                            <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if pedido.usuario %}
                                <div class="d-flex align-items-center gap-2">
                                    <span class="sz-badge-cat">{{ pedido.usuario.nombre }}</span>
                                    {% if pedido.estado != 'entregado' and pedido.estado != 'cancelado' %}
                                    <button class="sz-btn-asignar btn btn-sm btn-outline-secondary"
                                            data-id="{{ pedido.id }}"
                                            data-toggle="modal" data-target="#modalAsignar"
                                            title="Cambiar repartidor">
                                        <i class="fas fa-exchange-alt"></i>
                                    </button>
                                    {% endif %}
                                </div>
                            {% else %}
                                {% if pedido.estado != 'entregado' and pedido.estado != 'cancelado' %}
                                <button class="sz-btn-asignar btn btn-sm btn-outline-secondary"
                                        data-id="{{ pedido.id }}"
                                        data-toggle="modal" data-target="#modalAsignar">
                                    <i class="fas fa-user-plus mr-1"></i> Asignar
                                </button>
                                {% endif %}
                            {% endif %}
                        </td>
                        <td class="text-center">
                            <span class="sz-pedido-estado sz-estado--{{ pedido.estado }}">
                                {{ pedido.estado|capitalize }}
                            </span>
                        </td>
                        <td class="text-right sz-venta-monto">{{ _cfg.simbolo }}{{ pedido.total|number_format(2, '.', ',') }}</td>
                        <td>
                            <small class="text-muted">{{ pedido.created_at|date('d/m/Y H:i') }}</small>
                        </td>
                        <td class="text-center" style="white-space:nowrap">
                            <a href="{{ ('pedidos/detalle/' ~ pedido.id)|url }}"
                               class="btn btn-sm btn-outline-secondary mr-1" title="Ver detalle">
                                <i class="fas fa-eye"></i>
                            </a>
                            {% if pedido.estado == 'pendiente' %}
                            <button class="btn btn-sm btn-sz btn-avanzar-estado mr-1"
                                    data-id="{{ pedido.id }}" data-estado="confirmado" title="Confirmar">
                                <i class="fas fa-check"></i>
                            </button>
                            {% elseif pedido.estado == 'confirmado' %}
                            <button class="btn btn-sm btn-sz btn-avanzar-estado mr-1"
                                    data-id="{{ pedido.id }}" data-estado="enviado" title="Marcar como enviado">
                                <i class="fas fa-truck"></i>
                            </button>
                            {% elseif pedido.estado == 'enviado' %}
                            <button class="btn btn-sm btn-sz btn-avanzar-estado mr-1"
                                    data-id="{{ pedido.id }}" data-estado="entregado" title="Marcar como entregado">
                                <i class="fas fa-box-open"></i>
                            </button>
                            {% endif %}
                            {% if pedido.estado != 'entregado' and pedido.estado != 'cancelado' %}
                            <button class="btn btn-sm btn-outline-danger btn-cancelar-pedido"
                                    data-id="{{ pedido.id }}" title="Cancelar">
                                <i class="fas fa-ban"></i>
                            </button>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {# Paginación #}
        {% if total_pages > 1 %}
        <div class="sz-paginacion">
            {% set qs = (estado ? '&estado=' ~ estado : '') ~ (fecha_desde ? '&fecha_desde=' ~ fecha_desde : '') ~ (fecha_hasta ? '&fecha_hasta=' ~ fecha_hasta : '') %}
            {% if pagina > 1 %}
            <a href="{{ 'pedidos'|url }}?pagina={{ pagina - 1 }}{{ qs }}" class="sz-page-btn"><i class="fas fa-chevron-left"></i></a>
            {% endif %}
            {% for i in 1..total_pages %}
                {% if i == pagina %}
                    <span class="sz-page-btn sz-page-btn--active">{{ i }}</span>
                {% elseif i == 1 or i == total_pages or (i >= pagina - 2 and i <= pagina + 2) %}
                    <a href="{{ 'pedidos'|url }}?pagina={{ i }}{{ qs }}" class="sz-page-btn">{{ i }}</a>
                {% elseif i == pagina - 3 or i == pagina + 3 %}
                    <span class="sz-page-dots">…</span>
                {% endif %}
            {% endfor %}
            {% if pagina < total_pages %}
            <a href="{{ 'pedidos'|url }}?pagina={{ pagina + 1 }}{{ qs }}" class="sz-page-btn"><i class="fas fa-chevron-right"></i></a>
            {% endif %}
        </div>
        {% endif %}

        {% else %}
        <div class="sz-empty" style="padding:3rem">
            <i class="fas fa-shopping-bag fa-2x mb-3 d-block" style="color:var(--sz-border)"></i>
            No hay pedidos {% if estado %}con estado "{{ estado }}"{% endif %}
        </div>
        {% endif %}
    </div>
</div>

{# Modal asignar repartidor #}
<div class="modal fade" id="modalAsignar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content sz-modal">
            <div class="modal-header">
                <h5 class="modal-title">Asignar repartidor</h5>
                <button type="button" class="close" data-dismiss="modal"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="pedidoIdAsignar">
                <div class="form-group mb-0">
                    <label for="selectRepartidor">Selecciona el repartidor</label>
                    <select class="form-control" id="selectRepartidor">
                        <option value="">— Seleccionar —</option>
                        {% for rep in repartidores %}
                        <option value="{{ rep.usuario_id }}">{{ rep.usuario.nombre }} {{ rep.usuario.apellido }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-sz" id="btnConfirmarAsignar">
                    <i class="fas fa-user-check mr-1"></i> Asignar
                </button>
            </div>
        </div>
    </div>
</div>

{# Modal cancelar pedido #}
<div class="modal fade" id="modalCancelarPedido" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content sz-modal">
            <div class="modal-header">
                <h5 class="modal-title">Cancelar pedido</h5>
                <button type="button" class="close" data-dismiss="modal"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                ¿Deseas cancelar el pedido <strong id="folioCancelar"></strong>?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">No</button>
                <button type="button" class="btn btn-danger" id="btnConfirmarCancelar">
                    <i class="fas fa-ban mr-1"></i> Sí, cancelar
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
$(document).ready(function () {

    // Avanzar estado rápido
    $(document).on('click', '.btn-avanzar-estado', function () {
        var $btn   = $(this);
        var id     = $btn.data('id');
        var estado = $btn.data('estado');

        $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>');

        $.ajax({
            url: base_url('pedidos/estado'), method: 'POST',
            data: { id: id, estado: estado }, dataType: 'json',
            success: function (res) {
                if (res.response) location.reload();
                else { alert(res.message); $btn.prop('disabled', false); }
            },
            error: function () { $btn.prop('disabled', false); }
        });
    });

    // Asignar repartidor
    var pedidoIdAsignar = null;

    $(document).on('click', '.sz-btn-asignar', function () {
        pedidoIdAsignar = $(this).data('id');
    });

    $('#btnConfirmarAsignar').on('click', function () {
        var usuarioId = $('#selectRepartidor').val();
        if (!usuarioId) { alert('Selecciona un repartidor'); return; }

        $(this).prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Asignando...');

        $.ajax({
            url: base_url('pedidos/asignar'), method: 'POST',
            data: { id: pedidoIdAsignar, usuario_id: usuarioId }, dataType: 'json',
            success: function (res) {
                if (res.response) { $('#modalAsignar').modal('hide'); location.reload(); }
                else alert(res.message);
            },
            complete: function () {
                $('#btnConfirmarAsignar').prop('disabled', false)
                    .html('<i class="fas fa-user-check mr-1"></i> Asignar');
            }
        });
    });

    // Cancelar pedido
    var pedidoIdCancelar = null;

    $(document).on('click', '.btn-cancelar-pedido', function () {
        pedidoIdCancelar = $(this).data('id');
        $('#folioCancelar').text('#' + String(pedidoIdCancelar).padStart(5, '0'));
        $('#modalCancelarPedido').modal('show');
    });

    $('#btnConfirmarCancelar').on('click', function () {
        if (!pedidoIdCancelar) return;
        $(this).prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Cancelando...');

        $.ajax({
            url: base_url('pedidos/cancelar'), method: 'POST',
            data: { id: pedidoIdCancelar }, dataType: 'json',
            success: function (res) {
                if (res.response) { $('#modalCancelarPedido').modal('hide'); location.reload(); }
                else alert(res.message);
            },
            complete: function () {
                $('#btnConfirmarCancelar').prop('disabled', false)
                    .html('<i class="fas fa-ban mr-1"></i> Sí, cancelar');
            }
        });
    });

});
</script>
{% endblock %}
