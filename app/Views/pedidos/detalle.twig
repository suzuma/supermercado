{% extends "partials/new_layout.twig" %}

{% block content %}
<div class="sz-dashboard">

    <div class="sz-dash-header">
        <div>
            <h1 class="sz-dash-title">Pedido #{{ pedido.id|padLeft(5) }}</h1>
            <p class="sz-dash-sub">
                <a href="{{ 'pedidos'|url }}" class="sz-back-link">
                    <i class="fas fa-arrow-left mr-1"></i> Volver a pedidos
                </a>
            </p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ ('pedidos/orden/' ~ pedido.id)|url }}" target="_blank" class="btn btn-outline-secondary">
                <i class="fas fa-print mr-2"></i> Imprimir orden
            </a>
            {% if pedido.estado != 'entregado' and pedido.estado != 'cancelado' %}
            <button class="btn btn-danger btn-sm" id="btnCancelar">
                <i class="fas fa-ban mr-1"></i> Cancelar pedido
            </button>
            {% endif %}
        </div>
    </div>

    <div class="row">

        {# Columna principal #}
        <div class="col-lg-8">

            {# Timeline de estado #}
            <div class="sz-dash-card animate-in mb-3" style="--delay:.05s">
                <div class="sz-card-header">
                    <span class="sz-card-title"><i class="fas fa-map-marker-alt"></i> Estado del pedido</span>
                </div>
                <div class="p-4">
                    <div class="sz-timeline">
                        {% set estados = ['pendiente', 'confirmado', 'enviado', 'entregado'] %}
                        {% set estadoActual = pedido.estado %}
                        {% set cancelado = estadoActual == 'cancelado' %}

                        {% for est in estados %}
                        {% set activo = not cancelado and (
                            est == 'pendiente' or
                            (est == 'confirmado' and estadoActual in ['confirmado','enviado','entregado']) or
                            (est == 'enviado'    and estadoActual in ['enviado','entregado']) or
                            (est == 'entregado'  and estadoActual == 'entregado')
                        ) %}
                        <div class="sz-timeline-item {% if activo %}sz-timeline-item--done{% endif %} {% if est == estadoActual and not cancelado %}sz-timeline-item--current{% endif %}">
                            <div class="sz-timeline-dot">
                                {% if activo %}<i class="fas fa-check"></i>{% endif %}
                            </div>
                            <div class="sz-timeline-label">{{ est|capitalize }}</div>
                        </div>
                        {% if not loop.last %}
                        <div class="sz-timeline-line {% if activo %}sz-timeline-line--done{% endif %}"></div>
                        {% endif %}
                        {% endfor %}

                        {% if cancelado %}
                        <div class="sz-timeline-cancelado">
                            <i class="fas fa-ban mr-2"></i> Pedido cancelado
                        </div>
                        {% endif %}
                    </div>

                    {# Cambiar estado #}
                    {% if pedido.estado != 'entregado' and pedido.estado != 'cancelado' %}
                    <div class="sz-cambiar-estado mt-4">
                        <label class="sz-forma-label">Cambiar estado</label>
                        <div class="d-flex gap-2 flex-wrap">
                            {% if pedido.estado == 'pendiente' %}
                            <button class="btn btn-sz btn-cambiar-estado" data-estado="confirmado">
                                <i class="fas fa-check mr-1"></i> Confirmar pedido
                            </button>
                            {% endif %}
                            {% if pedido.estado == 'confirmado' %}
                            <button class="btn btn-sz btn-cambiar-estado" data-estado="enviado">
                                <i class="fas fa-truck mr-1"></i> Marcar como enviado
                            </button>
                            {% endif %}
                            {% if pedido.estado == 'enviado' %}
                            <button class="btn btn-sz btn-cambiar-estado" data-estado="entregado">
                                <i class="fas fa-box-open mr-1"></i> Marcar como entregado
                            </button>
                            {% endif %}
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>

            {# Productos del pedido #}
            <div class="sz-dash-card animate-in" style="--delay:.1s">
                <div class="sz-card-header">
                    <span class="sz-card-title"><i class="fas fa-boxes"></i> Productos</span>
                </div>
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-right">Precio u.</th>
                                <th class="text-right">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for detalle in pedido.detalles %}
                            <tr>
                                <td>
                                    <span class="sz-prod-nombre">{{ detalle.producto.nombre }}</span>
                                </td>
                                <td class="text-center">{{ detalle.cantidad }}</td>
                                <td class="text-right">{{ _cfg.simbolo }}{{ detalle.precio_unitario|number_format(2, '.', ',') }}</td>
                                <td class="text-right sz-venta-monto">{{ _cfg.simbolo }}{{ detalle.subtotal|number_format(2, '.', ',') }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-right font-weight-bold">Total</td>
                                <td class="text-right sz-venta-monto" style="font-size:1.1rem">
                                    {{ _cfg.simbolo }}{{ pedido.total|number_format(2, '.', ',') }}
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

        </div>

        {# Panel lateral #}
        <div class="col-lg-4">

            {# Info del cliente #}
            <div class="sz-dash-card animate-in mb-3" style="--delay:.15s">
                <div class="sz-card-header">
                    <span class="sz-card-title"><i class="fas fa-user"></i> Cliente</span>
                </div>
                <div class="p-3">
                    {% if pedido.cliente %}
                    <div class="sz-emp-info mb-3">
                        <div class="sz-emp-avatar">
                            {{ pedido.cliente.nombre|slice(0,1)|upper }}{{ pedido.cliente.apellido|slice(0,1)|upper }}
                        </div>
                        <div>
                            <span class="sz-prod-nombre">{{ pedido.cliente.nombre }} {{ pedido.cliente.apellido }}</span>
                            <small class="sz-prod-desc">{{ pedido.cliente.email }}</small>
                        </div>
                    </div>
                    <div class="sz-info-row">
                        <i class="fas fa-phone sz-info-icon"></i>
                        <span>{{ pedido.cliente.telefono ?? 'Sin teléfono' }}</span>
                    </div>
                    <div class="sz-info-row mt-2">
                        <i class="fas fa-map-marker-alt sz-info-icon"></i>
                        <span>{{ pedido.direccion_entrega }}</span>
                    </div>
                    {% else %}
                    <p class="text-muted mb-0">Sin cliente asignado</p>
                    {% endif %}
                </div>
            </div>

            {# Repartidor #}
            <div class="sz-dash-card animate-in mb-3" style="--delay:.2s">
                <div class="sz-card-header">
                    <span class="sz-card-title"><i class="fas fa-motorcycle"></i> Repartidor</span>
                </div>
                <div class="p-3">
                    {% if pedido.usuario %}
                    <div class="sz-emp-info">
                        <div class="sz-emp-avatar">
                            {{ pedido.usuario.nombre|slice(0,1)|upper }}{{ pedido.usuario.apellido|slice(0,1)|upper }}
                        </div>
                        <div>
                            <span class="sz-prod-nombre">{{ pedido.usuario.nombre }} {{ pedido.usuario.apellido }}</span>
                            <small class="sz-prod-desc">{{ pedido.usuario.email }}</small>
                        </div>
                    </div>
                    {% else %}
                    <p class="text-muted mb-2">Sin repartidor asignado</p>
                    {% if pedido.estado != 'entregado' and pedido.estado != 'cancelado' %}
                    <div class="form-group mb-2">
                        <select class="form-control" id="selectRepartidor">
                            <option value="">— Seleccionar repartidor —</option>
                            {% for rep in repartidores %}
                            <option value="{{ rep.usuario_id }}">{{ rep.usuario.nombre }} {{ rep.usuario.apellido }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <button class="btn btn-sz btn-block" id="btnAsignar">
                        <i class="fas fa-user-check mr-1"></i> Asignar repartidor
                    </button>
                    {% endif %}
                    {% endif %}
                </div>
            </div>

            {# Info del pedido #}
            <div class="sz-dash-card animate-in" style="--delay:.25s">
                <div class="sz-card-header">
                    <span class="sz-card-title"><i class="fas fa-info-circle"></i> Información</span>
                </div>
                <div class="p-3">
                    <div class="sz-info-row">
                        <span class="sz-info-label">Folio</span>
                        <code class="sz-codigo">#{{ pedido.id|padLeft(5) }}</code>
                    </div>
                    <div class="sz-info-row">
                        <span class="sz-info-label">Fecha</span>
                        <span>{{ pedido.created_at|date('d/m/Y H:i') }}</span>
                    </div>
                    <div class="sz-info-row">
                        <span class="sz-info-label">Estado</span>
                        <span class="sz-pedido-estado sz-estado--{{ pedido.estado }}">{{ pedido.estado|capitalize }}</span>
                    </div>
                    {% if pedido.fecha_entrega %}
                    <div class="sz-info-row">
                        <span class="sz-info-label">Entrega est.</span>
                        <span>{{ pedido.fecha_entrega|date('d/m/Y H:i') }}</span>
                    </div>
                    {% endif %}
                </div>
            </div>

        </div>
    </div>
</div>

{# Modal cancelar #}
<div class="modal fade" id="modalCancelar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content sz-modal">
            <div class="modal-header">
                <h5 class="modal-title">Cancelar pedido</h5>
                <button type="button" class="close" data-dismiss="modal"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                ¿Deseas cancelar el pedido <strong>#{{ pedido.id|padLeft(5) }}</strong>?
                Esta acción no se puede deshacer.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">No</button>
                <button type="button" class="btn btn-danger" id="btnConfirmarCancelar">
                    <i class="fas fa-ban mr-1"></i> Sí, cancelar
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
$(document).ready(function () {

    const pedidoId = {{ pedido.id }};

    // Cambiar estado
    $(document).on('click', '.btn-cambiar-estado', function () {
        const estado = $(this).data('estado');
        const btn    = $(this);

        btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Actualizando...');

        $.ajax({
            url:      base_url('pedidos/estado'),
            method:   'POST',
            data:     { id: pedidoId, estado },
            dataType: 'json',
            success: function (res) {
                if (res.response) location.reload();
                else alert(res.message);
            },
            complete: function () { btn.prop('disabled', false); }
        });
    });

    // Asignar repartidor
    $('#btnAsignar').on('click', function () {
        const usuarioId = $('#selectRepartidor').val();
        if (!usuarioId) { alert('Selecciona un repartidor'); return; }

        $(this).prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Asignando...');

        $.ajax({
            url:      base_url('pedidos/asignar'),
            method:   'POST',
            data:     { id: pedidoId, usuario_id: usuarioId },
            dataType: 'json',
            success: function (res) {
                if (res.response) location.reload();
                else alert(res.message);
            },
            complete: function () {
                $('#btnAsignar').prop('disabled', false)
                    .html('<i class="fas fa-user-check mr-1"></i> Asignar repartidor');
            }
        });
    });

    // Cancelar
    $('#btnCancelar').on('click', function () {
        $('#modalCancelar').modal('show');
    });

    $('#btnConfirmarCancelar').on('click', function () {
        $(this).prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Cancelando...');

        $.ajax({
            url:      base_url('pedidos/cancelar'),
            method:   'POST',
            data:     { id: pedidoId },
            dataType: 'json',
            success: function (res) {
                if (res.response) { $('#modalCancelar').modal('hide'); location.reload(); }
                else alert(res.message);
            },
            complete: function () {
                $('#btnConfirmarCancelar').prop('disabled', false)
                    .html('<i class="fas fa-ban mr-1"></i> Sí, cancelar');
            }
        });
    });

});
</script>
{% endblock %}
